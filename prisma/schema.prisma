generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  notifyDigest  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  goals               Goal[]
  ownedPitstops       Pitstop[]            @relation("PitstopOwner")
  programs            Program[]
  messages            Message[]
  mentions            Mention[]
  goalFollows         GoalFollow[]
  threadSubscriptions ThreadSubscription[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  createdEvents       PitstopEvent[]
  eventAttendances    PitstopEventAttendee[]
  planItems           PlanItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      GoalStatus @default(Active)
  recurrence  Recurrence @default(None)
  targetDate  DateTime?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner       User         @relation(fields: [ownerId], references: [id])
  pitstops    Pitstop[]
  attachments Attachment[]
  followers   GoalFollow[]
  programs    ProgramGoal[]
}

model Pitstop {
  id        String        @id @default(cuid())
  title     String
  type      PitstopType   @default(Discussion)
  notes     String?
  status    PitstopStatus @default(Upcoming)
  goalId          String
  ownerId         String?
  ownerInherited  Boolean       @default(true)
  customType      String?
  order           Int           @default(0)
  recurrence      PitstopRecurrence @default(None)
  startDate   DateTime?
  targetDate  DateTime?
  completedAt DateTime?
  deletedAt   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  goal           Goal               @relation(fields: [goalId], references: [id], onDelete: Cascade)
  owner          User?              @relation("PitstopOwner", fields: [ownerId], references: [id])
  threads        Thread[]
  attachments    Attachment[]
  checklistItems ChecklistItem[]
  blockedBy      PitstopDependency[] @relation("BlockedPitstop")
  blocking       PitstopDependency[] @relation("BlockingPitstop")
  reminderLogs   PitstopReminderLog[]
  checkinLog     PitstopCheckinLog?
  events         PitstopEventPitstop[]
  planItems      PlanItemPitstop[]
}

model ChecklistItem {
  id        String   @id @default(cuid())
  pitstopId String
  text      String
  checked   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
}

model PitstopDependency {
  id          String @id @default(cuid())
  blockedId   String
  blockedById String

  blocked   Pitstop @relation("BlockedPitstop",  fields: [blockedId],   references: [id], onDelete: Cascade)
  blockedBy Pitstop @relation("BlockingPitstop", fields: [blockedById], references: [id], onDelete: Cascade)

  @@unique([blockedId, blockedById])
}

model Thread {
  id        String   @id @default(cuid())
  name      String
  pitstopId String
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pitstop       Pitstop              @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  messages      Message[]
  subscriptions ThreadSubscription[]
}

model Message {
  id        String    @id @default(cuid())
  body      String
  authorId  String
  threadId  String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author      User         @relation(fields: [authorId], references: [id])
  thread      Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  mentions    Mention[]
}

model Attachment {
  id        String         @id @default(cuid())
  name      String
  type      AttachmentType @default(File)
  url       String
  size      Int?
  mimeType  String?
  messageId String?
  pitstopId String?
  goalId    String?
  createdAt DateTime       @default(now())

  message Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pitstop Pitstop? @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  goal    Goal?    @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Mention {
  id        String   @id @default(cuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model GoalFollow {
  id        String   @id @default(cuid())
  userId    String
  goalId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([userId, goalId])
}

model ThreadSubscription {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
}

enum NotificationType {
  Mention
  NewPitstop
  GoalStatusChange
  NewMessage
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum GoalStatus {
  Active
  Paused
  Complete
}

enum Recurrence {
  None
  Weekly
  Monthly
  Quarterly
  Yearly
}

enum PitstopStatus {
  Upcoming
  InProgress
  Done
}

enum PitstopType {
  Meeting
  Training
  SiteVisit
  Discussion
  AppDevelopment
  Budgeting
  Proposal
  Research
  Review
  Custom
}

enum AttachmentType {
  File
  Link
}

model CustomPitstopType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

enum PitstopRecurrence {
  None
  Weekly
  Monthly
  Quarterly
}

// Tracks the 3 one-shot reminders (10d / 3d / due-day) per pitstop
model PitstopReminderLog {
  id        String   @id @default(cuid())
  pitstopId String
  type      String   // "10d" | "3d" | "due"
  sentAt    DateTime @default(now())

  pitstop   Pitstop  @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([pitstopId, type])
}

// Tracks when we last sent an "any blockers?" check-in per pitstop
model PitstopCheckinLog {
  id         String   @id @default(cuid())
  pitstopId  String   @unique
  lastSentAt DateTime

  pitstop    Pitstop  @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
}

// Schedulable meetings / visits / events linked to a pitstop
enum PitstopEventType {
  Meeting
  Visit
  Event
}

model PitstopEvent {
  id          String           @id @default(cuid())
  title       String
  description String?
  type        PitstopEventType @default(Meeting)
  scheduledAt DateTime
  endsAt      DateTime?
  location    String?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy   User                   @relation(fields: [createdById], references: [id])
  attendees   PitstopEventAttendee[]
  pitstops    PitstopEventPitstop[]
}

model PitstopEventAttendee {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event PitstopEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model PitstopEventPitstop {
  id        String @id @default(cuid())
  eventId   String
  pitstopId String

  event   PitstopEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pitstop Pitstop      @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([eventId, pitstopId])
}

model Program {
  id          String    @id @default(cuid())
  title       String
  description String?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner User          @relation(fields: [ownerId], references: [id])
  goals ProgramGoal[]
}

model ProgramGoal {
  id        String @id @default(cuid())
  programId String
  goalId    String

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  goal    Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([programId, goalId])
}

model PlanItem {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  type        String    @default("Note")
  userId      String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitstops PlanItemPitstop[]
}

model PlanItemPitstop {
  id         String @id @default(cuid())
  planItemId String
  pitstopId  String

  planItem PlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  pitstop  Pitstop  @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([planItemId, pitstopId])
}

model AppSetting {
  key   String @id
  value String
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
