generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  bio              String?
  notifyDigest     Boolean   @default(false)
  weeklyCapacity   Float     @default(40)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  goals                Goal[]
  ownedPitstops        Pitstop[]             @relation("PitstopOwner")
  programs             Program[]
  messages             Message[]
  mentions             Mention[]
  goalFollows          GoalFollow[]
  threadSubscriptions  ThreadSubscription[]
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  createdEvents        PitstopEvent[]
  eventAttendances     PitstopEventAttendee[]
  eventFollowups       PitstopEventFollowup[]
  planItems            PlanItem[]
  // Accountability
  checkins             PitstopCheckin[]
  retrospectives       Retrospective[]
  standupLogs          StandupLog[]
  // Escalation
  escalationsGiven     PitstopEscalation[]   @relation("EscalatedBy")
  escalationsTaken     PitstopEscalation[]   @relation("EscalatedTo")
  // Co-ownership
  pitstopCoOwners      PitstopCoOwner[]
  goalCoOwners         GoalCoOwner[]
  // Decisions, Audit, Risks
  decisions            Decision[]
  auditLogs            AuditLog[]
  risks                Risk[]
  // Broadcasts & Metrics
  broadcasts           GoalBroadcast[]
  metricDataPoints     MetricDataPoint[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      GoalStatus @default(Active)
  recurrence  Recurrence @default(None)
  targetDate  DateTime?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner       User          @relation(fields: [ownerId], references: [id])
  pitstops    Pitstop[]
  attachments Attachment[]
  followers   GoalFollow[]
  programs    ProgramGoal[]
  // Co-ownership
  coOwners    GoalCoOwner[]
  // Decisions, risks, broadcasts
  decisions   Decision[]
  risks       Risk[]
  broadcasts  GoalBroadcast[]
  // Metrics/KPIs
  metrics     GoalMetric[]
  // Strategic tags
  themes      GoalTheme[]
  zones       GoalZone[]
  clusters    GoalCluster[]
  settlements GoalSettlement[]
  quarters    GoalQuarter[]
}

model Pitstop {
  id              String            @id @default(cuid())
  title           String
  type            PitstopType       @default(Discussion)
  notes           String?
  status          PitstopStatus     @default(Upcoming)
  priority        PitstopPriority   @default(Medium)
  goalId          String
  ownerId         String?
  ownerInherited  Boolean           @default(true)
  customType      String?
  order           Int               @default(0)
  recurrence      PitstopRecurrence @default(None)
  estimatedHours  Float?
  startDate       DateTime?
  targetDate      DateTime?
  completedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  goal           Goal                @relation(fields: [goalId], references: [id], onDelete: Cascade)
  owner          User?               @relation("PitstopOwner", fields: [ownerId], references: [id])
  threads        Thread[]
  attachments    Attachment[]
  checklistItems ChecklistItem[]
  blockedBy      PitstopDependency[] @relation("BlockedPitstop")
  blocking       PitstopDependency[] @relation("BlockingPitstop")
  reminderLogs   PitstopReminderLog[]
  checkinLog     PitstopCheckinLog?
  events         PitstopEventPitstop[]
  planItems      PlanItemPitstop[]
  // New relations
  coOwners       PitstopCoOwner[]
  escalations    PitstopEscalation[]
  checkins       PitstopCheckin[]
  standupLinks   StandupLogPitstop[]
  risks          Risk[]
}

model ChecklistItem {
  id        String   @id @default(cuid())
  pitstopId String
  text      String
  checked   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
}

model PitstopDependency {
  id          String @id @default(cuid())
  blockedId   String
  blockedById String

  blocked   Pitstop @relation("BlockedPitstop",  fields: [blockedId],   references: [id], onDelete: Cascade)
  blockedBy Pitstop @relation("BlockingPitstop", fields: [blockedById], references: [id], onDelete: Cascade)

  @@unique([blockedId, blockedById])
}

model Thread {
  id        String    @id @default(cuid())
  name      String
  pitstopId String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  pitstop       Pitstop              @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  messages      Message[]
  subscriptions ThreadSubscription[]
}

model Message {
  id        String    @id @default(cuid())
  body      String
  authorId  String
  threadId  String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author      User         @relation(fields: [authorId], references: [id])
  thread      Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  mentions    Mention[]
}

model Attachment {
  id        String         @id @default(cuid())
  name      String
  type      AttachmentType @default(File)
  url       String
  size      Int?
  mimeType  String?
  messageId String?
  pitstopId String?
  goalId    String?
  createdAt DateTime       @default(now())

  message Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pitstop Pitstop? @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  goal    Goal?    @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Mention {
  id        String   @id @default(cuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model GoalFollow {
  id        String   @id @default(cuid())
  userId    String
  goalId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([userId, goalId])
}

model ThreadSubscription {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
}

// ── Notifications ─────────────────────────────────────────────────────────────

enum NotificationType {
  Mention
  NewPitstop
  GoalStatusChange
  NewMessage
  PitstopStatusChange
  GoalFollowed
  ActivityTagged
  ActivityFollowup
  ActivityMorningNudge
  WeeklyPlanNudge
  CheckinReminder
  EscalationAlert
  BroadcastUpdate
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum GoalStatus {
  Active
  Paused
  Complete
}

enum Recurrence {
  None
  Weekly
  Monthly
  Quarterly
  Yearly
}

enum PitstopStatus {
  Upcoming
  InProgress
  Done
}

enum PitstopPriority {
  High
  Medium
  Low
}

enum PitstopType {
  Meeting
  Training
  SiteVisit
  Discussion
  AppDevelopment
  Budgeting
  Proposal
  Research
  Review
  Custom
}

enum AttachmentType {
  File
  Link
}

enum PitstopRecurrence {
  None
  Weekly
  Monthly
  Quarterly
}

enum PitstopEventStatus {
  Scheduled
  Done
  Cancelled
  Flagged
}

enum CheckinStatus {
  OnTrack
  AtRisk
  Blocked
  Done
}

enum DecisionStatus {
  Open
  Made
  Reversed
}

enum RiskLikelihood {
  Low
  Medium
  High
}

enum RiskImpact {
  Low
  Medium
  High
}

enum RiskStatus {
  Open
  Mitigated
  Closed
}

enum MetricFrequency {
  Daily
  Weekly
  Monthly
  Quarterly
}

// ── Accountability ────────────────────────────────────────────────────────────

model PitstopCheckin {
  id        String        @id @default(cuid())
  pitstopId String
  userId    String
  date      DateTime      @default(now())
  status    CheckinStatus
  note      String?
  nextSteps String?
  createdAt DateTime      @default(now())

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Retrospective {
  id           String   @id @default(cuid())
  entityType   String   // "Goal" | "Pitstop"
  entityId     String
  authorId     String
  wentWell     String?
  couldImprove String?
  keyLearning  String?
  createdAt    DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model StandupLog {
  id        String    @id @default(cuid())
  userId    String
  date      DateTime
  yesterday String?
  today     String?
  blockers  String?
  createdAt DateTime  @default(now())

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitstops StandupLogPitstop[]
}

model StandupLogPitstop {
  standupLogId String
  pitstopId    String

  standupLog StandupLog @relation(fields: [standupLogId], references: [id], onDelete: Cascade)
  pitstop    Pitstop    @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@id([standupLogId, pitstopId])
}

// ── Escalation ────────────────────────────────────────────────────────────────

model PitstopEscalation {
  id             String    @id @default(cuid())
  pitstopId      String
  escalatedById  String
  escalatedToId  String
  note           String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  pitstop     Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  escalatedBy User    @relation("EscalatedBy", fields: [escalatedById], references: [id], onDelete: Cascade)
  escalatedTo User    @relation("EscalatedTo", fields: [escalatedToId], references: [id], onDelete: Cascade)
}

// ── Co-ownership ──────────────────────────────────────────────────────────────

model PitstopCoOwner {
  pitstopId String
  userId    String

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pitstopId, userId])
}

model GoalCoOwner {
  goalId String
  userId String

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([goalId, userId])
}

// ── Decision Log ──────────────────────────────────────────────────────────────

model Decision {
  id          String         @id @default(cuid())
  title       String
  description String?
  rationale   String?
  status      DecisionStatus @default(Open)
  decidedAt   DateTime?
  goalId      String?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  goal      Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  createdBy User  @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// ── Audit Trail ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   // "Goal" | "Pitstop"
  entityId   String
  userId     String
  action     String   // "status_change" | "owner_change" | "date_change" | "priority_change" | "created" | "deleted"
  field      String?
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
}

// ── Risk Registry ─────────────────────────────────────────────────────────────

model Risk {
  id          String         @id @default(cuid())
  title       String
  description String?
  likelihood  RiskLikelihood @default(Medium)
  impact      RiskImpact     @default(Medium)
  mitigation  String?
  status      RiskStatus     @default(Open)
  goalId      String?
  pitstopId   String?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  goal      Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)
  pitstop   Pitstop? @relation(fields: [pitstopId], references: [id], onDelete: SetNull)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// ── Broadcast Updates ─────────────────────────────────────────────────────────

model GoalBroadcast {
  id        String    @id @default(cuid())
  goalId    String
  authorId  String
  title     String
  body      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  goal   Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ── Metrics / KPIs ────────────────────────────────────────────────────────────

model GoalMetric {
  id          String          @id @default(cuid())
  goalId      String
  name        String
  description String?
  target      Float
  current     Float           @default(0)
  unit        String?
  frequency   MetricFrequency @default(Monthly)
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  goal       Goal              @relation(fields: [goalId], references: [id], onDelete: Cascade)
  dataPoints MetricDataPoint[]
}

model MetricDataPoint {
  id        String   @id @default(cuid())
  metricId  String
  value     Float
  note      String?
  date      DateTime
  userId    String
  createdAt DateTime @default(now())

  metric GoalMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Themes ────────────────────────────────────────────────────────────────────

model Theme {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  goals GoalTheme[]
}

model GoalTheme {
  goalId  String
  themeId String

  goal  Goal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([goalId, themeId])
}

// ── Geography: Zone → Cluster → Settlement ───────────────────────────────────

model Zone {
  id        String    @id @default(cuid())
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  clusters Cluster[]
  goals    GoalZone[]
}

model Cluster {
  id        String    @id @default(cuid())
  name      String
  zoneId    String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  zone        Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  settlements Settlement[]
  goals       GoalCluster[]
}

model Settlement {
  id        String    @id @default(cuid())
  name      String
  clusterId String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  cluster Cluster        @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  goals   GoalSettlement[]
}

model GoalZone {
  goalId String
  zoneId String

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([goalId, zoneId])
}

model GoalCluster {
  goalId    String
  clusterId String

  goal    Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  cluster Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@id([goalId, clusterId])
}

model GoalSettlement {
  goalId       String
  settlementId String

  goal       Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@id([goalId, settlementId])
}

// ── Quarterly Planning ────────────────────────────────────────────────────────

model Quarter {
  id        String    @id @default(cuid())
  year      Int
  quarter   Int       // 1–4
  startDate DateTime
  endDate   DateTime
  focus     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  goals GoalQuarter[]

  @@unique([year, quarter])
}

model GoalQuarter {
  goalId    String
  quarterId String

  goal    Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  quarter Quarter @relation(fields: [quarterId], references: [id], onDelete: Cascade)

  @@id([goalId, quarterId])
}

// ── Legacy / Utility ──────────────────────────────────────────────────────────

model CustomPitstopType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model PitstopReminderLog {
  id        String   @id @default(cuid())
  pitstopId String
  type      String   // "10d" | "3d" | "due"
  sentAt    DateTime @default(now())

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([pitstopId, type])
}

model PitstopCheckinLog {
  id         String   @id @default(cuid())
  pitstopId  String   @unique
  lastSentAt DateTime

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
}

enum PitstopEventType {
  Meeting
  Visit
  Event
}

model PitstopEvent {
  id          String             @id @default(cuid())
  title       String
  description String?
  type        PitstopEventType   @default(Meeting)
  status      PitstopEventStatus @default(Scheduled)
  scheduledAt DateTime
  endsAt      DateTime?
  location    String?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  createdBy User                      @relation(fields: [createdById], references: [id])
  attendees PitstopEventAttendee[]
  pitstops  PitstopEventPitstop[]
  followups PitstopEventFollowup[]
}

model PitstopEventFollowup {
  id          String                      @id @default(cuid())
  eventId     String
  userId      String
  response    PitstopEventFollowupStatus?
  sentAt      DateTime
  nudgeSentAt DateTime?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  event PitstopEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

enum PitstopEventFollowupStatus {
  Done
  No
  Cancelled
  Rescheduled
}

model PitstopEventAttendee {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event PitstopEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model PitstopEventPitstop {
  id        String @id @default(cuid())
  eventId   String
  pitstopId String

  event   PitstopEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pitstop Pitstop      @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([eventId, pitstopId])
}

model Program {
  id          String    @id @default(cuid())
  title       String
  description String?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner User          @relation(fields: [ownerId], references: [id])
  goals ProgramGoal[]
}

model ProgramGoal {
  id        String @id @default(cuid())
  programId String
  goalId    String

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  goal    Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([programId, goalId])
}

model PlanItem {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  type        String    @default("Note")
  userId      String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitstops PlanItemPitstop[]
}

model PlanItemPitstop {
  id         String @id @default(cuid())
  planItemId String
  pitstopId  String

  planItem PlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  pitstop  Pitstop  @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([planItemId, pitstopId])
}

model AppSetting {
  key   String @id
  value String
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
