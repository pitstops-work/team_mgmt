  @@index([userId, createdAt])
}

// Admin-configurable registry of facility layer types shown in template builder + goal wizard
model FacilityLayerConfig {
  id          String   @id @default(cuid())
  layerKey    String   @unique
  label       String
  color       String   @default("#6366f1")
  needsDomain String? // links to NeedsFormulaConfig.domain — ties this layer to a field-coverage need
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Budget Tool ──────────────────────────────────────────────────────────────

// BudgetDomain is no longer an enum — domain keys are plain strings
// configured via BudgetDomainConfig (admin-editable from /admin).

model BudgetDomainConfig {
  id               String   @id @default(cuid())
  city             String   @default("Bangalore")
  key              String // stored in domain fields, e.g. "Children"
  label            String // display name, e.g. "Elderly + Community Kitchen"
  description      String?
  position         Int      @default(0)
  isActive         Boolean  @default(true)
  // For per-beneficiary cost analysis
  beneficiaryLabel String? // e.g. "Children", "Youth enrolled"
  beneficiaryVar   String? // programme input key: "nCLCs", "nElderly", "nCreches", "nSettlements"
  beneficiaryMult  Float    @default(1) // multiply beneficiaryVar by this
  createdAt        DateTime @default(now())

  @@unique([city, key])
  @@index([city, position])
}

enum BudgetStatus {
  draft
  final
  approved
}

enum ReportFrequency {
  monthly
  bi_monthly
  quarterly
  half_yearly
  annual
}

enum ReportSlotStatus {
  pending
  submitted
  under_review
  sent_back
  approved
}

enum ReallocationStatus {
  pending
  approved
  rejected
}

enum ReallocationDuration {
  remaining_year
  full_grant
  custom
  one_time
}

enum InflationType {
  Salary
  Other
  Nil
}

enum BudgetSection {
  salary
  capex
  travel
  programme
  admin_salary
  admin_other
  additional
}

model Budget {
  id                 String              @id @default(cuid())
  name               String
  partnerId          String
  partner            User                @relation("BudgetPartner", fields: [partnerId], references: [id])
  // Grantee org this budget belongs to (spans many budgets). Distinct from
  // partnerId (the User who created it). Null on legacy rows until assigned.
  grantPartnerId     String?
  grantPartner       GrantPartner?       @relation(fields: [grantPartnerId], references: [id], onDelete: SetNull)
  domains            String[]
  city               String              @default("Bangalore")
  // years is kept for backward compat; horizonMonths is the source of truth.
  // years = ceil(horizonMonths / 12) is maintained at write time so list/select
  // queries that read `years` keep working without a sweep.
  years              Int                 @default(1)
  horizonMonths      Int                 @default(12)
  // Where the pro-rated stub sits when horizonMonths isn't a whole number of
  // years: "end" (default — final band is partial) or "start" (Year 1 partial,
  // e.g. a project starting mid-year).
  partialPosition    String              @default("end")
  // When true, the budget is split across delivery partners (see
  // BudgetDeliveryPartner). Lines carry deliveryPartnerId; null = shared/master.
  isMultiPartner     Boolean             @default(false)
  applyInflation     Boolean             @default(true)
  // Per-budget inflation rates as percentages (e.g. 10 = 10%). Defaults track
  // the previously hard-coded values in lib/budget-generator.ts.
  inflationSalaryPct Float               @default(10)
  inflationOtherPct  Float               @default(5)
  inflationNilPct    Float               @default(0)
  // Per-budget cost customisation. Sparse map of CostRegistry.itemKey → value
  // that the partner edited at create time; the snapshot is the full registry
  // view at create time and is what the generator merges overrides on top of.
  // Snapshot lets future "regenerate" or "scale up" actions reproduce the
  // partner's basis even if the registry has changed.
  costOverrides      Json                @default("{}")
  costSnapshot       Json                @default("{}")
  // Set when the budget was created by importing a filled Excel template rather
  // than the parametric generator. Its lines carry hand edits, so a "regenerate
  // from inputs" action must confirm before overwriting them.
  importedAt         DateTime?
  status             BudgetStatus        @default(draft)
  inputs             BudgetInputs?
  lines              BudgetLine[]
  deliveryPartners   BudgetDeliveryPartner[]
  reportConfig       BudgetReportConfig?
  reportSlots        BudgetReportSlot[]
  reports            BudgetReport[]
  borrowingsFrom     GrantBorrowing[]    @relation("BorrowingFrom")
  borrowingsTo       GrantBorrowing[]    @relation("BorrowingTo")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([partnerId])
  @@index([grantPartnerId])
}

// A grantee organisation (e.g. "CFAR", "Sampark"). Spans many budgets/grants so
// the dashboard can aggregate approved amounts + utilisation per partner. City-
// scoped so the same name can exist independently under Bangalore/Chennai/Others.
model GrantPartner {
  id        String   @id @default(cuid())
  name      String
  city      String   @default("Bangalore") // Bangalore | Chennai | Others
  notes     String?
  isActive  Boolean  @default(true)
  // Optional login account for this grantee (a User with role "partner"). Lets
  // the grantee sign in and file their own reports. One account per grantee.
  userId    String?  @unique
  user      User?    @relation("PartnerLogin", fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  budgets   Budget[]

  @@unique([city, name])
  @@index([city])
}

enum GrantBorrowingStatus {
  outstanding
  partially_reimbursed
  reimbursed
}

// Cross-grant borrowing: a partner spends one grant's cash on another grant's
// work (disbursement timing), reimbursing later. Distinct from
// BudgetReallocationRequest, which moves money only WITHIN one budget. Net
// position as of any date = Σ amount(borrowedOn ≤ D) − Σ repayment(repaidOn ≤ D).
model GrantBorrowing {
  id           String                    @id @default(cuid())
  fromBudgetId String // lender grant (money came from)
  toBudgetId   String // borrower grant (work belonged to)
  fromBudget   Budget                    @relation("BorrowingFrom", fields: [fromBudgetId], references: [id], onDelete: Cascade)
  toBudget     Budget                    @relation("BorrowingTo", fields: [toBudgetId], references: [id], onDelete: Cascade)
  amount       Float
  borrowedOn   DateTime
  reason       String?
  status       GrantBorrowingStatus      @default(outstanding)
  createdById  String?
  createdAt    DateTime                  @default(now())
  repayments   GrantBorrowingRepayment[]

  @@index([fromBudgetId])
  @@index([toBudgetId])
}

// Partial repayments of a borrowing over time — kept as rows so the net
// outstanding position is accurate as of any point in time.
model GrantBorrowingRepayment {
  id          String         @id @default(cuid())
  borrowingId String
  borrowing   GrantBorrowing @relation(fields: [borrowingId], references: [id], onDelete: Cascade)
  amount      Float
  repaidOn    DateTime
  note        String?

  @@index([borrowingId])
}

model BudgetInputs {
  id                        String @id @default(cuid())
  budgetId                  String @unique
  budget                    Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  nSettlements              Int    @default(0)
  nClusters                 Int    @default(0)
  nCLCs                     Int    @default(0)
  clcRentPerMonth           Int    @default(0)
  nYRCs                     Int    @default(0)
  yrcRentPerMonth           Int    @default(0)
  nElderlyCentres           Int    @default(0)
  nElderly                  Int    @default(0)
  elderlyCentreRentPerMonth Int    @default(0)
  cosPerCluster             Int    @default(2)
  rcRentPerMonth            Int    @default(0)
  nCreches                  Int    @default(0)
  crecheRentPerMonth        Int    @default(0)
  extraInputs               Json   @default("{}") // custom programme inputs added via admin
}

model BudgetLine {
  id                       String                      @id @default(cuid())
  budgetId                 String
  budget                   Budget                      @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  // Delivery-partner this line belongs to in a multi-partner budget. null =
  // shared / cross-cutting (Master tab). SetNull so removing a partner leaves
  // its lines as shared rather than deleting them.
  deliveryPartnerId        String?
  deliveryPartner          BudgetDeliveryPartner?      @relation(fields: [deliveryPartnerId], references: [id], onDelete: SetNull)
  domain                   String?
  section                  BudgetSection
  position                 Int
  description              String
  costCategory             InflationType
  unitType                 String                      @default("")
  isAutoGenerated          Boolean                     @default(true)
  salaryHint               String?
  notes                    String?
  templateKey              String? // links back to LineTemplate.templateKey for cost-driver trail in exports
  y1Units                  Float                       @default(0)
  y1UnitCost               Float                       @default(0)
  y1AllocPct               Float                       @default(1)
  y1Total                  Float                       @default(0)
  y2Units                  Float                       @default(0)
  y2UnitCost               Float                       @default(0)
  y2AllocPct               Float                       @default(1)
  y2Total                  Float                       @default(0)
  y3Units                  Float                       @default(0)
  y3UnitCost               Float                       @default(0)
  y3AllocPct               Float                       @default(1)
  y3Total                  Float                       @default(0)
  y4Units                  Float                       @default(0)
  y4UnitCost               Float                       @default(0)
  y4AllocPct               Float                       @default(1)
  y4Total                  Float                       @default(0)
  y5Units                  Float                       @default(0)
  y5UnitCost               Float                       @default(0)
  y5AllocPct               Float                       @default(1)
  y5Total                  Float                       @default(0)
  isReallocation           Boolean                     @default(false)
  sourceReallocationId     String?
  // Timing profile for period-budget apportionment in reports.
  //   monthly  → straight-line yearTotal/12 × monthsInPeriod (default).
  //   one_time → full yearTotal lands in plannedMonths[0] (1..12 of grant year).
  //   seasonal → yearTotal split evenly across plannedMonths (≥ 2 entries).
  cadence                  BudgetLineCadence           @default(monthly)
  plannedMonths            Int[]                       @default([])
  reportLines              BudgetReportLine[]
  reallocationRequestsFrom BudgetReallocationRequest[] @relation("ReallocationFrom")
  reallocationRequestsTo   BudgetReallocationRequest[] @relation("ReallocationTo")

  @@index([budgetId, position])
  @@index([deliveryPartnerId])
}

// A delivery/implementing partner sharing a multi-partner budget. Distinct from
// Budget.partnerId (the creator user). Each holds its own programme inputs (its
// slice of the totals) and an explicit % of shared/cross-cutting costs
// (sharedPct across all partners should sum to 100).
model BudgetDeliveryPartner {
  id        String       @id @default(cuid())
  budgetId  String
  budget    Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int          @default(0)
  sharedPct Float        @default(0)
  inputs    Json         @default("{}")
  lines     BudgetLine[]

  @@index([budgetId])
}

enum BudgetLineCadence {
  monthly
  one_time
  seasonal
}

model BudgetReportConfig {
  id             String          @id @default(cuid())
  budgetId       String          @unique
  budget         Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  frequency      ReportFrequency
  grantStartDate DateTime
  grantEndDate   DateTime
  dueAfterDays   Int             @default(30)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model BudgetReportSlot {
  id         String           @id @default(cuid())
  budgetId   String
  budget     Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  slotNumber Int
  grantYear  Int
  periodFrom DateTime
  periodTo   DateTime
  dueDate    DateTime
  status     ReportSlotStatus @default(pending)
  report     BudgetReport?
  createdAt  DateTime         @default(now())

  @@unique([budgetId, slotNumber])
  @@index([budgetId, grantYear])
}

model BudgetReport {
  id                   String                      @id @default(cuid())
  slotId               String                      @unique
  slot                 BudgetReportSlot            @relation(fields: [slotId], references: [id], onDelete: Cascade)
  budgetId             String
  budget               Budget                      @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  openingBalance       Float                       @default(0)
  tranchesReceived     Float                       @default(0)
  interestEarned       Float                       @default(0)
  bankBalance          Float                       @default(0)
  fdBalance            Float                       @default(0)
  cashInHand           Float                       @default(0)
  advances             Float                       @default(0)
  receivables          Float                       @default(0)
  payables             Float                       @default(0)
  bankStatementUrl     String?
  bankStatementParsed  Json?
  partnerNotes         String?
  reviewerNotes        String?
  submittedAt          DateTime?
  approvedAt           DateTime?
  // Finance Declaration (legal affirmation captured at submit). Snapshot + hash
  // freeze exactly what was affirmed; identity/ip/ua are the audit trail; the
  // signed+sealed scan is the letterhead artifact. declarationAcceptedById is a
  // plain id (no FK) so the record survives user renames/deletes.
  declarationAcceptedAt     DateTime?
  declarationAcceptedById   String?
  declarationSnapshot       Json?
  declarationHash           String?
  declarationIp             String?
  declarationUserAgent      String?
  declarationSignedScanUrl  String?
  lines                BudgetReportLine[]
  reallocationRequests BudgetReallocationRequest[]
  fdDetails            BudgetReportFd[]
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([budgetId])
}

// One row per fixed deposit held during the reporting period, in the APF
// "Format for FD details" layout. fdBalance on BudgetReport is kept in sync as
// the sum of closingBalance across these rows.
model BudgetReportFd {
  id               String       @id @default(cuid())
  reportId         String
  report           BudgetReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sortOrder        Int          @default(0)
  bankName         String       @default("")
  fdrNumber        String       @default("") // FDR / receipt number
  faceValue        Float        @default(0)
  maturityValue    Float        @default(0)
  cumulative       Boolean      @default(true) // Cumulative vs Non-Cumulative
  doi              DateTime? // Date of Investment
  dom              DateTime? // Date of Maturity (per FD terms)
  roi              Float        @default(0) // Rate of Interest (%)
  openingBalance   Float        @default(0)
  interestAccrued  Float        @default(0)
  tds              Float        @default(0)
  interestReceived Float        @default(0)
  maturedAmount    Float        @default(0) // Matured during the period
  maturityDate     DateTime? // Actual maturity/redemption date in period
  closingBalance   Float        @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([reportId])
}

model BudgetReallocationRequest {
  id              String               @id @default(cuid())
  reportId        String
  report          BudgetReport         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fromLineId      String
  fromLine        BudgetLine           @relation("ReallocationFrom", fields: [fromLineId], references: [id], onDelete: Cascade)
  toLineId        String?
  toLine          BudgetLine?          @relation("ReallocationTo", fields: [toLineId], references: [id], onDelete: SetNull)
  toDescription   String?
  toSection       BudgetSection?
  requestedAmount Float
  isRecurring     Boolean              @default(false)
  monthlyAmount   Float                @default(0)
  durationType    ReallocationDuration
  durationMonths  Int?
  rationale       String
  sourceUnspent   Float                @default(0)
  willSustain     Boolean              @default(true)
  sustainNote     String?
  status          ReallocationStatus   @default(pending)
  approvedAmount  Float?
  reviewerComment String?
  resolvedAt      DateTime?
  createdLineId   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([reportId])
  @@index([fromLineId])
}

model BudgetReportLine {
  id           String       @id @default(cuid())
  reportId     String
  report       BudgetReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  budgetLineId String
  budgetLine   BudgetLine   @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  actualAmount Float        @default(0)
  notes        String?

  @@unique([reportId, budgetLineId])
  @@index([reportId])
}

model CostRegistry {
  id            String   @id @default(cuid())
  city          String   @default("Bangalore")
  domain        String?
  itemKey       String
  unitCost      Float
  unit          String
  effectiveYear Int      @default(2025)
  notes         String?
  // Free-text "how this rate was arrived at" for items that don't decompose
  // into components (e.g. "avg of 3 vendor quotes"). Complements the structured
  // CostRegistryComponent breakup.
  derivation    String?
  displayGroup  String? // for inp.* items: "geography" | "facilities" | "coverage"; null → coverage
  needsDomain   String? // for inp.* items: links to NeedsFormulaConfig.domain for scenario loading
  updatedAt     DateTime @updatedAt

  @@unique([city, itemKey])
}

// Append-only change log for CostRegistry unit costs. Written on every registry
// mutation (seed, admin edit, reset, reseed). Reproduction of old budgets is
// already handled by Budget.costSnapshot; this table exists for the reflective
// "what changed, when, why" trail across cost revisions. Generic across domains.
//   oldCost null  → item created
//   newCost null  → item deleted
model CostRegistryHistory {
  id          String   @id @default(cuid())
  city        String
  domain      String?
  itemKey     String
  oldCost     Float?
  newCost     Float?
  source      String? // "Urban Creche V.2 May25" | "admin edit" | "seed" | "reset"
  reason      String?
  changedById String?
  changedAt   DateTime @default(now())

  @@index([city, itemKey, changedAt])
}

// Structured breakup of an aggregate CostRegistry item (e.g. an asset bundle
// that sums many sub-items). Optional & additive: items with no components keep
// their flat hand-entered unitCost. Where components exist, the parent's
// unitCost is the roll-up Σ(qty × unitCost) and the Working sheet expands these
// rows so the derivation stays visible. Generic across all domains.
model CostRegistryComponent {
  id            String  @id @default(cuid())
  city          String
  parentItemKey String // FK-by-convention to CostRegistry.itemKey (same city)
  position      Int     @default(0)
  label         String
  spec          String? // free-text specification from the cost book
  qty           Float   @default(1)
  unitCost      Float // amount = qty × unitCost
  notes         String?
  updatedAt     DateTime @updatedAt

  @@index([city, parentItemKey, position])
}

// Each row is one generated line in a budget.
// The formula fields fully describe how to compute unitCount and unitCost
// from programme inputs (nCLCs, nCreches, etc.) and the cost registry.
//
// Unit count:
//   inputVar     – which programme input scales this line
//                  "fixed_1"|"fixed_12"|"nCLCs"|"nYRCs"|"nSettlements"|
//                  "nClusters"|"nElderly"|"nElderlyCentres"|"nCreches"|"cosTotal"
//   inputMonthly – multiply by 12 (monthly → annual)
//   supervisorRatioKey – if set: units = ceil(inp[inputVar] / reg[key]) × 12
//
// Unit cost (evaluated in order – first matching rule wins):
//   isSalaryStub   – cost = 0 (user fills salary)
//   userInputCost  – cost = programme input field (rent entered by user)
//   costPctOf      – cost = reg[costPctOf] × costPct / 100
//   workerRatioKey – cost = reg[wKey] × reg[costKey] × 12 × (1 + reg[bufferKey]/100)
//   costKey[2][3]  – cost = reg[k1] × reg[k2?] × reg[k3?] × (12 if costMonthly)
//
// y1UnitsZero: override Y1 units to 0 (e.g. CAPEX maintenance starts Y2)
model LineTemplate {
  id              String        @id @default(cuid())
  city            String
  domain          String?
  section         BudgetSection
  description     String
  costCategory    InflationType
  unitType        String        @default("")
  position        Int
  isActive        Boolean       @default(true)
  isAutoGenerated Boolean       @default(true)
  notes           String?
  salaryHint      String?
  templateKey     String // stable slug used for upsert seeding

  // unit count
  inputVar           String  @default("fixed_1")
  inputMonthly       Boolean @default(false)
  supervisorRatioKey String?
  inputThreshold     Int? // if set: suppress line (units=0) when inputVar value <= this

  // unit cost
  isSalaryStub   Boolean @default(false)
  userInputCost  String?
  costKey        String?
  costKey2       String?
  costKey3       String?
  costMonthly    Boolean @default(false)
  workerRatioKey String?
  bufferKey      String?
  costPctOf      String?
  costPct        Float?
  y1UnitsZero    Boolean @default(false)

  // Year applicability & expansion / reduction
  applyY1      Boolean @default(true)
  applyY2      Boolean @default(true)
  applyY3      Boolean @default(true)
  y2UnitsScale Float? // null = same as Y1; 1.5 = 50% more; 0.5 = 50% fewer
  y3UnitsScale Float?

  @@unique([city, templateKey])
  @@index([city, domain, position])
}

// ── Layer 3: Programme Journeys ──────────────────────────────────────────────
// Threads connecting multiple goals (across templates / over time) under a
// shared outcome objective. Auto-spawned per (domain, settlement) on goal
// apply. Phases form a DAG (linear by default; admin can rewire).

model ProgrammeJourney {
  id              String    @id @default(cuid())
  // Stable slug for ops + dedupe, e.g. "creche-munireddypalya"
  key             String    @unique
  label           String
  // Auto-linking dimension. Null when admin makes a cross-domain super-journey.
  primaryDomain   String?
  settlementId    String
  status          String    @default("Active") // Active | Paused | Closed
  notes           String?
  // Closure metadata
  closedAt        DateTime?
  closedReason    String?
  closedById      String?
  // Snapshot of final outcome values at closure time (JSON: { outcomeKey: value })
  outcomeSnapshot Json?
  // Optional pointer to a parent super-journey (cross-domain aggregation).
  parentId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  settlement Settlement                @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  parent     ProgrammeJourney?         @relation("ProgrammeJourneyChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children   ProgrammeJourney[]        @relation("ProgrammeJourneyChildren")
  phases     ProgrammeJourneyPhase[]
  outcomes   ProgrammeJourneyOutcome[]
  closedBy   User?                     @relation("JourneyClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([settlementId, primaryDomain])
  @@index([parentId])
}

model ProgrammeJourneyPhase {
  id        String   @id @default(cuid())
  journeyId String
  // Layout hint only — real ordering is the DAG (edges)
  position  Int      @default(0)
  label     String // "Setup" | "Operations" | "Maintenance" | custom
  // Canvas coordinates for the DAG view. Null = auto-layout.
  canvasX   Int?
  canvasY   Int?
  // The fulfilling goal. Null = logical/planned phase not yet started.
  goalId    String?
  status    String   @default("Planned") // Planned | Active | Done | Skipped
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journey  ProgrammeJourney            @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  goal     Goal?                       @relation(fields: [goalId], references: [id], onDelete: SetNull)
  outEdges ProgrammeJourneyPhaseEdge[] @relation("PhaseOutEdges")
  inEdges  ProgrammeJourneyPhaseEdge[] @relation("PhaseInEdges")

  @@index([journeyId])
  @@index([goalId])
}

model ProgrammeJourneyPhaseEdge {
  id          String  @id @default(cuid())
  fromPhaseId String
  toPhaseId   String
  label       String? // "after creche running", "in parallel"

  from ProgrammeJourneyPhase @relation("PhaseOutEdges", fields: [fromPhaseId], references: [id], onDelete: Cascade)
  to   ProgrammeJourneyPhase @relation("PhaseInEdges", fields: [toPhaseId], references: [id], onDelete: Cascade)

  @@unique([fromPhaseId, toPhaseId])
}

model ProgrammeJourneyOutcome {
  id                  String   @id @default(cuid())
  journeyId           String
  key                 String // unique within journey
  label               String
  description         String?
  unit                String?
  // MANUAL_ADMIN | RP_ACTIVITY (mirrors FacilityIndicatorSource)
  captureSource       String   @default("MANUAL_ADMIN")
  // For RP_ACTIVITY: bind to a checklist key (one binding per outcome in v1)
  bindingTemplateSlug String?
  bindingChecklistKey String?
  targetValue         Float?
  targetCadence       String? // "annual" | "quarterly" | "monthly"
  sortOrder           Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  journey ProgrammeJourney               @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  points  ProgrammeJourneyOutcomePoint[]

  @@unique([journeyId, key])
}

model ProgrammeJourneyOutcomePoint {
  id           String   @id @default(cuid())
  outcomeId    String
  value        Float
  capturedAt   DateTime
  source       String // MANUAL_ADMIN | RP_ACTIVITY
  capturedById String?
  sourceRefId  String? // ChecklistItem.id for RP_ACTIVITY
  note         String?
  createdAt    DateTime @default(now())

  outcome    ProgrammeJourneyOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  capturedBy User?                   @relation("JourneyOutcomeCapture", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([outcomeId, capturedAt])
}

// Outcome templates — admin-defined packs that can be applied to any journey
// matching a target domain. Each pack contains one or more outcome definitions
// (label / unit / target / capture mode) that get cloned into a journey on apply.
model ProgrammeJourneyOutcomeTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  // Optional domain filter — admin can apply this pack only to journeys whose
  // primaryDomain matches (or to any journey if null).
  domain    String?
  notes     String?
  // JSON array of outcome definitions to clone into the journey on apply.
  // Shape: [{ key, label, unit, captureSource, bindingTemplateSlug?, bindingChecklistKey?, targetValue?, targetCadence? }]
  outcomes  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── RBAC ──────────────────────────────────────────────────────────────────────
// Centralized role/permission system. User.role (string) is the canonical role
// identifier; it matches Role.name 1:1. Keeping the string column avoids a
// breaking schema change for now — a future migration can swap to an FK.

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "super-admin" | "admin" | "member" | "viewer" | "budget-admin"
  description String?
  isSystem    Boolean  @default(true) // System roles cannot be deleted from admin UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
}

model Permission {
  id        String   @id @default(cuid())
  resource  String // "goal" | "pitstop" | "user" | "thread" | ...
  action    String // "list" | "read" | "create" | "update" | "delete" | special verbs
  createdAt DateTime @default(now())

  roles RolePermission[]

  @@unique([resource, action])
}

// Pivot with the *scope rule* attached. The rule is jsonb so the admin UI can
// edit predicates without a schema migration. See lib/rbac.ts for evaluators.
model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  scopeRule    Json // { kind: "all" | "self" | "own" | "team" | "city" | ... }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
}

// ── Org ──────────────────────────────────────────────────────────────────────
// Tenancy / partner identification. Internal staff share the "Pitstops
// Internal" org seeded via prisma/seed-wiki.ts. Partner NGO orgs are added
// later when partner-user onboarding ships.
model Org {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  kind         String // "internal" | "partner"
  // Partner-identity columns. Lifted from the old MapPartner model so every
  // partner-shaped reference (Settlement, Cluster, LayerFeature, Wiki, User)
  // can point at the same row. mapKey is the legacy LAYERS slug used to
  // colorise polygons — nullable for internal orgs and any partner that
  // doesn't have its own map layer. archivedAt is the soft-delete signal;
  // partner FKs use SetNull so historical references survive removal.
  color        String?   @default("#6366f1")
  mapKey       String?   @unique
  contactName  String?
  contactPhone String?
  contactEmail String?
  notes        String?
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users                 User[]
  partnerReviewMeetings WikiPartnerReviewMeeting[] @relation("WikiPartnerReviewMeetingOrg")
  wikiPracticeGaps      WikiPracticeGap[]          @relation("WikiPracticeGapPartnerOrg")
  wikiObservations      WikiPracticeObservation[]  @relation("WikiPracticeObservationPartnerOrg")
  wikiPracticeEntries   WikiPracticeEntry[]        @relation("WikiPracticeEntryPartnerOrg")
  // Partner-org geo bindings (added 2026-06-04, replaces MapPartner relations
  // and LayerFeature.partner free-text). See migration M2.
  settlementsAsPartner  Settlement[]               @relation("SettlementPartnerOrg")
  clustersAsPartner     Cluster[]                  @relation("ClusterPartnerOrg")
  facilitiesAsPartner   LayerFeature[]             @relation("LayerFeaturePartnerOrg")
}

// ── Wiki module ──────────────────────────────────────────────────────────────
// Owner-driven knowledge/practice pages. Per-page owner sits on WikiPage.ownerId;
// global steward/curator powers live in WikiStaff (decoupled from User.role).
// Tag values are free strings under tagType taxonomies. Translations live in
// translatedContent as { lang: { content, translatedAt } }.

model WikiPage {
  id                String    @id @default(cuid())
  slug              String    @unique
  title             String
  type              String // "principle" | "playbook" | "runbook" | "manual"
  // Manual subtype: ground-truth density signal. NULL for non-manual pages.
  // "mostly_theory" | "emerging" | "seasoned". Orthogonal to status — status
  // tracks editorial state; maturity tracks how field-tested the content is.
  maturity          String?
  // Restricted-handling flag (e.g. mental health, GBV modules). When true the
  // reader shows a sensitive banner; field-level RBAC gating is layered later.
  isSensitive       Boolean   @default(false)
  sensitiveNote     String? // restricted-handling instruction shown on the reader
  canonicalLang     String    @default("en") // en | ta | kn | ml | hi | bn
  canonicalContent  String    @default("") // markdown serialised from Tiptap (unused for manual subtype — see WikiManualSection)
  translatedContent Json      @default("{}") // { ta: { content, translatedAt }, ... }
  ownerId           String?
  ownerTermStart    DateTime?
  ownerTermEnd      DateTime?
  nextReviewDue     DateTime?
  lastReviewedAt    DateTime?
  lastEditedAt      DateTime  @default(now())
  lastEditedById    String?
  status            String    @default("draft") // draft | published | under_review | orphaned | retired
  createdAt         DateTime  @default(now())
  archivedAt        DateTime?
  archivedById      String?

  owner                 User?                      @relation("WikiPageOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  lastEditor            User?                      @relation("WikiPageLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  tags                  WikiPageTag[]
  versions              WikiPageVersion[]
  comments              WikiComment[]
  flags                 WikiFlag[]
  reviews               WikiReviewCycle[]
  notifLogs             WikiNotificationLog[]
  practiceCircles       WikiPracticeCircle[]       @relation("WikiPracticeCirclePages")
  partnerReviewMeetings WikiPartnerReviewMeeting[] @relation("WikiPartnerReviewMeetingPages")
  handovers             WikiOwnerHandover[]
  translationFlags      WikiTranslationFlag[]
  views                 WikiPageView[]
  practiceGaps          WikiPracticeGap[]          @relation("WikiPracticeGapLinkedPage")
  observations          WikiPracticeObservation[]  @relation("WikiPracticeObservationPrimaryPage")
  // Manual subtype
  manualSections        WikiManualSection[]
  practiceEntries       WikiPracticeEntry[]
  boundariesFrom        WikiManualBoundary[]       @relation("WikiManualBoundaryFrom")
  boundariesTo          WikiManualBoundary[]       @relation("WikiManualBoundaryTo")

  @@index([status])
  @@index([type])
  @@index([type, maturity])
  @@index([nextReviewDue])
  @@index([ownerId])
  @@index([ownerTermEnd])
}

model WikiPageTag {
  id       String @id @default(cuid())
  pageId   String
  tagType  String // "vertical" | "city" | "partner_org" | "activity_type"
  tagValue String

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, tagType, tagValue])
  @@index([tagType, tagValue])
}

model WikiPageVersion {
  id              String   @id @default(cuid())
  pageId          String
  versionNumber   Int
  contentSnapshot String // full markdown at this version
  language        String // which language was edited
  editedById      String
  editedAt        DateTime @default(now())
  changeNote      String?

  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  editor User     @relation("WikiPageVersionEditor", fields: [editedById], references: [id])

  @@unique([pageId, versionNumber])
  @@index([editedById])
}

model WikiComment {
  id            String    @id @default(cuid())
  pageId        String
  authorId      String
  sectionAnchor String?
  body          String
  language      String
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
  resolvedById  String?

  page       WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author     User     @relation("WikiCommentAuthor", fields: [authorId], references: [id])
  resolvedBy User?    @relation("WikiCommentResolver", fields: [resolvedById], references: [id])

  @@index([pageId])
  @@index([authorId])
}

model WikiFlag {
  id            String    @id @default(cuid())
  pageId        String
  flaggerId     String
  sectionAnchor String?
  reason        String
  status        String    @default("open") // open | acknowledged | resolved
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  page    WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  flagger User     @relation("WikiFlagFlagger", fields: [flaggerId], references: [id])

  @@index([pageId, status])
  @@index([flaggerId])
}

model WikiReviewCycle {
  id                            String    @id @default(cuid())
  pageId                        String
  ownerId                       String
  scheduledFor                  DateTime
  completedAt                   DateTime?
  completionNote                String?
  type                          String // quarterly | post_circle | post_partner_review
  // Legacy free-string trigger from PR1 — superseded by the FK columns below,
  // kept nullable for safety. New code should write to triggerCircleId or
  // triggerPartnerReviewMeetingId instead.
  triggerSourceId               String?
  triggerCircleId               String?
  triggerPartnerReviewMeetingId String?
  createdAt                     DateTime  @default(now())

  page                        WikiPage                  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  owner                       User                      @relation("WikiReviewCycleOwner", fields: [ownerId], references: [id])
  triggerCircle               WikiPracticeCircle?       @relation(fields: [triggerCircleId], references: [id], onDelete: SetNull)
  triggerPartnerReviewMeeting WikiPartnerReviewMeeting? @relation(fields: [triggerPartnerReviewMeetingId], references: [id], onDelete: SetNull)

  @@unique([pageId, triggerCircleId])
  @@unique([pageId, triggerPartnerReviewMeetingId])
  @@index([pageId])
  @@index([ownerId, completedAt])
}

model WikiStaff {
  id        String   @id @default(cuid())
  userId    String
  wikiRole  String // "curator" | "steward"
  scope     Json? // { cities: [...], verticals: [...] } — null = global
  createdAt DateTime @default(now())

  user User @relation("WikiStaffUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, wikiRole])
  @@index([wikiRole])
}

// Notification dispatch audit log. Captures every intended wiki-related
// notification (push / inApp / whatsapp) with status so we can debug why a
// digest didn't fire, and so the WhatsApp adapter — currently a stub — leaves
// a paper trail of "would have sent" intent until the provider is chosen.
model WikiNotificationLog {
  id        String   @id @default(cuid())
  userId    String
  pageId    String?
  kind      String // "wiki_flag_created" | "wiki_comment_created" | "wiki_weekly_digest" | ...
  channel   String // "push" | "inApp" | "whatsapp"
  status    String // "sent" | "skipped" | "failed" | "intended_no_adapter"
  payload   Json
  error     String?
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  page WikiPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([pageId])
  @@index([kind, createdAt])
}

// Practice circle: scheduled internal meeting (vertical + zone scoped) where
// staff discuss a case. Pages linked here get a "review within 7 days" prompt
// to their owners once the circle is marked completed.
model WikiPracticeCircle {
  id            String    @id @default(cuid())
  scheduledFor  DateTime
  completedAt   DateTime?
  vertical      String?
  zoneId        String?
  facilitatorId String
  caseDiscussed String?
  notes         String?
  recordingUrl  String?
  language      String    @default("en")
  // Soft-delete. Lists, dashboards, crons all filter archivedAt: null.
  archivedAt    DateTime?
  archivedById  String?
  createdAt     DateTime  @default(now())

  zone            Zone?               @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  facilitator     User                @relation("WikiPracticeCircleFacilitator", fields: [facilitatorId], references: [id])
  attendees       User[]              @relation("WikiPracticeCircleAttendees")
  linkedPages     WikiPage[]          @relation("WikiPracticeCirclePages")
  reviewCycles    WikiReviewCycle[]
  practiceEntries WikiPracticeEntry[] @relation("WikiPracticeEntryCircle")

  @@index([scheduledFor])
  @@index([facilitatorId])
  @@index([zoneId])
  @@index([archivedAt])
}

// Partner review meeting: scheduled session with a partner NGO where the team
// notes any changes to shared practice. Linked pages get the same post-event
// review prompt as practice circles.
model WikiPartnerReviewMeeting {
  id                   String    @id @default(cuid())
  partnerOrgId         String
  scheduledFor         DateTime
  completedAt          DateTime?
  practiceChangesNoted String?
  notes                String?
  language             String    @default("en")
  // Soft-delete. Lists, dashboards, crons all filter archivedAt: null.
  archivedAt           DateTime?
  archivedById         String?
  createdAt            DateTime  @default(now())

  partnerOrg   Org               @relation("WikiPartnerReviewMeetingOrg", fields: [partnerOrgId], references: [id])
  attendees    User[]            @relation("WikiPartnerReviewMeetingAttendees")
  linkedPages  WikiPage[]        @relation("WikiPartnerReviewMeetingPages")
  reviewCycles WikiReviewCycle[]

  @@index([scheduledFor])
  @@index([partnerOrgId])
  @@index([archivedAt])
}

// Pending or completed owner handover. The owner initiates by inserting a
// pending row addressed to the proposed new owner; the proposed owner then
// accepts (which flips WikiPage.ownerId + resets the term) or declines.
model WikiOwnerHandover {
  id           String    @id @default(cuid())
  pageId       String
  fromUserId   String
  toUserId     String
  handoverNote String?
  status       String    @default("pending") // pending | accepted | declined
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  page     WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  fromUser User     @relation("WikiHandoverFrom", fields: [fromUserId], references: [id])
  toUser   User     @relation("WikiHandoverTo", fields: [toUserId], references: [id])

  @@index([pageId, status])
  @@index([toUserId, status])
}

// Reader-flagged translation quality issue. Goes to a queue for human review.
// Per-language so the same page can have flags against different translations
// simultaneously.
model WikiTranslationFlag {
  id         String    @id @default(cuid())
  pageId     String
  language   String // target language code: ta | kn | ml | hi | bn | en
  flaggerId  String
  reason     String
  status     String    @default("open") // open | resolved
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  page    WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  flagger User     @relation(fields: [flaggerId], references: [id])

  @@index([status])
  @@index([pageId, language])
}

// Per-user, per-page view record — written at most once per (user, page, day)
// from the reader server page. Visible only to stewards and curators per spec
// ("Do not show view counts or popularity to owners or readers — avoids vanity
// dynamics distorting content").
model WikiPageView {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  createdAt DateTime @default(now())

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([userId, createdAt])
}

// Practice gap queue: "there is no page for the thing I am doing today."
// Distinct from WikiFlag (which targets an existing page). A gap has no
// pageId at file time. The curator's weekly walk routes it to an owner who
// drafts a page; the gap closes when the page publishes, with linkedPageId
// pointing back at it. See public/training/modules/practice-documentation/
// 05-practice-gap-queue.html for the protocol.
model WikiPracticeGap {
  id               String    @id @default(cuid())
  vertical         String // e.g. "food", "creche", "welfare-rights"
  oneLineNeed      String // the gap, in one sentence
  suggestedTitle   String? // optional — owner may rename
  city             String? // bangalore | chennai | null (universal)
  partnerOrgId     String? // optional partner scope
  filerId          String
  status           String    @default("open") // open | assigned | drafted | merged | published | declined
  assignedOwnerId  String?
  curatorTriagerId String?
  triagedAt        DateTime?
  draftingDeadline DateTime?
  // When status flips to merged/published, points at the page that absorbed
  // or fulfilled the gap. Allows the filer-loop notification + cross-link.
  linkedPageId     String?
  declineReason    String?
  // Soft-delete (distinct from resolvedAt, which is a triage outcome).
  archivedAt       DateTime?
  archivedById     String?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?

  filer          User      @relation("WikiPracticeGapFiler", fields: [filerId], references: [id])
  assignedOwner  User?     @relation("WikiPracticeGapAssignee", fields: [assignedOwnerId], references: [id], onDelete: SetNull)
  curatorTriager User?     @relation("WikiPracticeGapTriager", fields: [curatorTriagerId], references: [id], onDelete: SetNull)
  partnerOrg     Org?      @relation("WikiPracticeGapPartnerOrg", fields: [partnerOrgId], references: [id], onDelete: SetNull)
  linkedPage     WikiPage? @relation("WikiPracticeGapLinkedPage", fields: [linkedPageId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([vertical, status])
  @@index([assignedOwnerId, status])
  @@index([filerId])
  @@index([createdAt])
  @@index([archivedAt])
}

// Field shadow visits and new-CO onboarding sessions. Shared model with a
// `kind` discriminator — both observations capture the same shape: an observer
// (owner / RP), an observed person (CO), a partner / vertical / city, notes,
// optional drift flag, optional primary page touched. See module 6 of the
// practice-documentation training.
model WikiPracticeObservation {
  id             String    @id @default(cuid())
  kind           String // "shadow" | "onboarding"
  observerId     String
  observedUserId String?
  partnerOrgId   String?
  vertical       String
  city           String?
  happenedAt     DateTime
  notes          String    @default("")
  openQuestions  String?
  // True when the observation revealed drift between page and practice — the
  // observer also files a flag against the page. Useful for the dashboard.
  driftFlagged   Boolean   @default(false)
  // Single page this observation primarily touched. Nullable: onboarding may
  // span many pages, shadow visits may touch none yet (gap incoming).
  primaryPageId  String?
  // Soft-delete. Lists, dashboards, crons all filter archivedAt: null.
  archivedAt     DateTime?
  archivedById   String?
  createdAt      DateTime  @default(now())

  observer    User      @relation("WikiPracticeObservationObserver", fields: [observerId], references: [id], onDelete: Restrict)
  observed    User?     @relation("WikiPracticeObservationObserved", fields: [observedUserId], references: [id], onDelete: SetNull)
  partnerOrg  Org?      @relation("WikiPracticeObservationPartnerOrg", fields: [partnerOrgId], references: [id], onDelete: SetNull)
  primaryPage WikiPage? @relation("WikiPracticeObservationPrimaryPage", fields: [primaryPageId], references: [id], onDelete: SetNull)

  @@index([kind, happenedAt])
  @@index([observerId, happenedAt])
  @@index([partnerOrgId, kind])
  @@index([vertical, happenedAt])
  @@index([archivedAt])
}

// ─── Response Manual (wiki manual subtype) ───────────────────────────────────
// A manual is a WikiPage with type="manual". Its content is sectioned (8 fixed
// sections, see lib/wiki/manual.ts) rather than the free-form Tiptap blob in
// WikiPage.canonicalContent. Spine sections (S2/S3/S7) are owner-edited; living
// sections (S4/S6/S8) grow primarily through WikiPracticeEntry append-only
// captures fed by practice circles, partner reviews, and shadow visits.

// One row per (manual, sectionNumber). Section content is markdown, matching
// WikiPage.canonicalContent conventions so the same renderer applies.
model WikiManualSection {
  id             String   @id @default(cuid())
  pageId         String
  sectionNumber  Int // 1..8, see lib/wiki/manual.ts SECTION_LABELS
  content        String   @default("") // markdown (canonical lang of the parent page)
  lastEditedAt   DateTime @default(now())
  lastEditedById String?

  page       WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  lastEditor User?    @relation("WikiManualSectionEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)

  @@unique([pageId, sectionNumber])
  @@index([pageId])
}

// Append-only practice-circle feed targeting a specific manual section.
// Default destination is section 6 ("where it gets stuck") — most circle output
// is failures/workarounds. Editors promote recurring entries to a standard
// branch in section 5 by stamping promotedToSectionNumber + promotedById.
model WikiPracticeEntry {
  id                      String    @id @default(cuid())
  pageId                  String // the manual
  sectionNumber           Int // which slot, 1..8
  body                    String
  observerId              String // CO / RP / facilitator who captured this
  settlement              String? // free-text location (e.g. "Semmancherry")
  partnerOrgId            String?
  happenedAt              DateTime
  status                  String    @default("raw") // raw | reviewed | promoted
  promotedToSectionNumber Int? // typically 5, when promoted from S6 anecdote
  promotedById            String?
  promotedAt              DateTime?
  // Optional source — when the entry was captured inside a circle session.
  circleId                String?
  // Soft-delete (entries are otherwise immutable for shelf-life integrity).
  archivedAt              DateTime?
  archivedById            String?
  createdAt               DateTime  @default(now())

  page       WikiPage            @relation(fields: [pageId], references: [id], onDelete: Cascade)
  observer   User                @relation("WikiPracticeEntryObserver", fields: [observerId], references: [id], onDelete: Restrict)
  partnerOrg Org?                @relation("WikiPracticeEntryPartnerOrg", fields: [partnerOrgId], references: [id], onDelete: SetNull)
  promoter   User?               @relation("WikiPracticeEntryPromoter", fields: [promotedById], references: [id], onDelete: SetNull)
  circle     WikiPracticeCircle? @relation("WikiPracticeEntryCircle", fields: [circleId], references: [id], onDelete: SetNull)

  @@index([pageId, sectionNumber])
  @@index([pageId, status])
  @@index([observerId, happenedAt])
  @@index([status, createdAt])
  @@index([circleId])
  @@index([archivedAt])
}

// Typed module-to-module edge. "hands_off" = a hard handoff the CO must take
// (e.g. Mental Health → Safety Pathway on self-harm risk). "draws_on" = shared
// content / cross-reference. Both endpoints must be WikiPage rows with
// type="manual"; not enforced at the DB level (cheap to check in the app).
model WikiManualBoundary {
  id         String   @id @default(cuid())
  fromPageId String
  toPageId   String
  kind       String // "hands_off" | "draws_on"
  note       String? // e.g. "trigger: any expression of self-harm risk"
  createdAt  DateTime @default(now())

  fromPage WikiPage @relation("WikiManualBoundaryFrom", fields: [fromPageId], references: [id], onDelete: Cascade)
  toPage   WikiPage @relation("WikiManualBoundaryTo", fields: [toPageId], references: [id], onDelete: Cascade)

  @@unique([fromPageId, toPageId, kind])
  @@index([fromPageId])
  @@index([toPageId])
}

// ─── Operating Models (parametric unit-economics engine) ─────────────────────
// Templates are *data*, not code. Same pattern as GoalTemplateDef.
// See memory/operating_models.md for the full design.

model ModelTemplate {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "ro_water"
  name        String
  description String   @default("")
  // Time bases this template uses, e.g. [{key:"monthly",length:60},{key:"annual",length:5}].
  // Author-defined; nodes bind to one of these keys (or "scalar").
  horizons    Json     @default("[]")
  // Optional ordering hint for /models lists
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groups    ModelGroup[]
  nodes     ModelNode[]
  outputs   ModelOutput[]
  instances ModelInstance[]
}

// UI grouping for inputs in the play surface (e.g. "Site & Population", "Pricing").
model ModelGroup {
  id         String        @id @default(cuid())
  templateId String
  template   ModelTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key        String // unique within a template
  label      String
  order      Int           @default(0)
  // Which play surface this group's inputs belong to: "finance" | "sim" | "both".
  // Drives tab-filtering in the play workbench. Nodes inherit unless they override.
  surface    String        @default("both")
  createdAt  DateTime      @default(now())

  nodes ModelNode[]

  @@unique([templateId, key])
  @@index([templateId, order])
}

// A node in the model graph: input cell, formula cell, constant, or table.
// shape encodes whether it's a scalar or vector tied to a template horizon.
// shape examples: {kind:"scalar"} | {kind:"vector", horizon:"monthly"}
model ModelNode {
  id          String        @id @default(cuid())
  templateId  String
  template    ModelTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  groupId     String?
  group       ModelGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  key         String // unique within a template; referenced by formulas
  label       String
  notes       String?
  unit        String? // free text: "INR/litre", "%", "kWh/1000L"
  kind        String // "input" | "formula" | "constant"
  dataType    String // "number" | "percent" | "currency" | "int" | "boolean" | "enum"
  shape       Json          @default("{\"kind\":\"scalar\"}")
  // Default value for input/constant nodes. For vectors, may be a single number
  // (broadcast) or an array. Formulas ignore this.
  defaultJson Json?
  // For formula nodes: the expression source. Null for inputs/constants.
  formula     String?
  // For enum dataType: array of allowed values.
  enumValues  Json?
  // Play-surface this node belongs to: "finance" | "sim" | "both". Overrides the
  // group's surface when not "both". Finance-only nodes vanish on the sim tab and
  // vice-versa; "both" nodes (e.g. plant capacity, price, tank size) show on both.
  surface     String        @default("both")
  // Detail tier for the sim tab's Basic/Advanced toggle: "basic" | "advanced".
  // Advanced nodes (engineering constants) stay hidden until the toggle flips.
  // Ignored on the finance/editor tabs, which always show every tier.
  tier        String        @default("basic")
  // Optional slider config for the sim tab: { min, max, step }. Present → render
  // a slider+readout; absent → typed number input.
  uiJson      Json?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([templateId, key])
  @@index([templateId, order])
  @@index([groupId])
}

// Author-defined outputs to render: KPI cards, time-series, sensitivity grids,
// scenario comparisons, budget exports. kind drives the renderer; config is
// renderer-specific.
model ModelOutput {
  id         String        @id @default(cuid())
  templateId String
  template   ModelTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key        String
  label      String
  // "kpi" | "series" | "table" | "sensitivity" | "scenarioGrid" | "budgetExport"
  kind       String
  config     Json          @default("{}")
  order      Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([templateId, key])
  @@index([templateId, order])
}

// A saved set of input overrides for a template. Nullable pitstopId supports
// standalone-first then attach-later. parentInstanceId links scenario siblings.
model ModelInstance {
  id               String          @id @default(cuid())
  templateId       String
  template         ModelTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name             String
  pitstopId        String?
  // For scenarios: Conservative/Base/Optimistic share parentInstanceId.
  parentInstanceId String?
  parent           ModelInstance?  @relation("ModelInstanceScenarios", fields: [parentInstanceId], references: [id], onDelete: SetNull)
  scenarios        ModelInstance[] @relation("ModelInstanceScenarios")
  scenarioName     String?
  // Sparse: only the nodes the user has overridden vs. node defaults.
  // Shape: { [nodeKey]: number | number[] | boolean | string }
  inputsJson       Json            @default("{}")
  // Setting publicSlug exposes the instance read-only at /models-public/<slug>.
  // No auth required; sliders are local-only (never persisted). Null = private.
  publicSlug       String?         @unique
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([templateId, updatedAt])
  @@index([pitstopId])
  @@index([parentInstanceId])
}

// ── Action Points ─────────────────────────────────────────────────────────────
// Follow-ups that emerge during an activity (PitstopEvent). Always rooted in
// the Goal → Pitstop → PitstopEvent hierarchy — never standalone. goalId and
// pitstopId are denormalized from the PitstopEvent at create-time so Home
// queries (today / overdue / cluster-scoped) are one-hop.
//
// V1 design notes (locked 2026-06-03):
//   - Owner is always the RP themself at creation. `partnerStaffLabel` is a
//     free-text note ("Creche supervisor at Sanjay Gandhinagar") — the RP
//     carries the AP and closes it when the partner action lands. No WhatsApp
//     bridge yet.
//   - Status is open|done|cancelled. No verify step — assignee close is final.
//     Reopen is available from the Done bucket for ~14d via API.
//   - Close authority mirrors pitstop_event.update — owner + ZL/PM/Leader can
//     mark done on the RP's behalf (cluster-scoped).
//   - Capture is manual only in v1: rows added inline on the activity close-out
//     modal. Voice extraction / WhatsApp loop are deferred.
model ActionPoint {
  id String @id @default(cuid())

  // Hierarchy — always required, denormalized for fast queries
  goalId         String
  pitstopId      String
  pitstopEventId String

  // Content
  title             String
  detail            String?
  partnerStaffLabel String? // free-text — "creche supervisor", "ZL Ravi", etc.

  // Ownership / lifecycle
  ownerId  String // = RP (always self at creation; ZL/PM/Leader may close on their behalf)
  dueDate  DateTime
  priority String   @default("routine") // routine | urgent

  status          String    @default("open") // open | done | cancelled
  closureNote     String?
  closureProofUrl String?
  completedAt     DateTime?
  completedById   String?

  // Bookkeeping
  createdAt       DateTime @default(now())
  createdById     String
  updatedAt       DateTime @updatedAt
  lastUpdatedById String?

  // Relations
  goal          Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  pitstop       Pitstop      @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  pitstopEvent  PitstopEvent @relation(fields: [pitstopEventId], references: [id], onDelete: Cascade)
  owner         User         @relation("ActionPointOwner", fields: [ownerId], references: [id])
  createdBy     User         @relation("ActionPointCreator", fields: [createdById], references: [id])
  lastUpdatedBy User?        @relation("ActionPointLastUpdater", fields: [lastUpdatedById], references: [id])
  completedBy   User?        @relation("ActionPointCompleter", fields: [completedById], references: [id])

  @@index([ownerId, status, dueDate])
  @@index([pitstopEventId])
  @@index([pitstopId])
  @@index([goalId])
  @@index([status, dueDate])
}

// ── Wiki v2 — Articles + Spine ─────────────────────────────────────────────
// New programme-reference wiki. Each programme has a spine (e.g. the EVRAT
// questionnaire for Elderly) of question articles; each question links to
// companion articles in 3 panels (guideline / care_plan / action_manual).
// Articles are atomic units of content: edit once → reflected everywhere they
// appear. The Fork action duplicates an article when a question genuinely
// needs divergent content. See /Users/vishnuharikumar/.claude/plans/async-snacking-hippo.md.

model WikiArticle {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  // 'question' | 'guideline_appendix' | 'care_plan_derivation' | 'pathway'
  // | 'template' | 'chapter' | 'framework' | 'flag_protocol'
  kind          String
  // Matches NeedsFormulaConfig.domain. 'Elderly' for v1.
  programDomain String
  // TipTap JSON doc. Preserves mentions (wikilinks), tables, formatting.
  contentJson   Json
  // Sort within kind for category pages.
  naturalOrder  Int       @default(0)

  // Soft-delete. Lists, spines, categories, search all filter archivedAt: null.
  archivedAt   DateTime?
  archivedById String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedById  String
  updatedAt    DateTime  @updatedAt
  // Set on Fork — points to the article this one was forked from. Lets us
  // trace lineage; does NOT propagate edits.
  forkedFromId String?

  createdBy   User                 @relation("WikiArticleCreator", fields: [createdById], references: [id])
  updatedBy   User                 @relation("WikiArticleUpdater", fields: [updatedById], references: [id])
  archivedBy  User?                @relation("WikiArticleArchiver", fields: [archivedById], references: [id])
  forkedFrom  WikiArticle?         @relation("WikiArticleForks", fields: [forkedFromId], references: [id])
  forks       WikiArticle[]        @relation("WikiArticleForks")
  versions    WikiArticleVersion[]
  // Links FROM this article (where this is the question; targets show in fork panels).
  outboundLinks WikiArticleLink[]  @relation("WikiArticleLinkFrom")
  // Links TO this article (where this article appears in someone else's fork panel).
  inboundLinks  WikiArticleLink[]  @relation("WikiArticleLinkTo")
  spineEntries  WikiSpineEntry[]

  @@index([programDomain, kind, naturalOrder])
  @@index([archivedAt])
  @@index([forkedFromId])
}

model WikiArticleVersion {
  id            String   @id @default(cuid())
  articleId     String
  versionNumber Int
  title         String
  contentJson   Json
  savedAt       DateTime @default(now())
  savedById     String
  // Optional change note ("first draft", "fixed typo in para 3", etc.)
  summary       String?

  article WikiArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  savedBy User        @relation("WikiArticleVersionSaver", fields: [savedById], references: [id])

  @@unique([articleId, versionNumber])
  @@index([savedById])
}

model WikiArticleLink {
  id            String @id @default(cuid())
  // The question article (where the fork buttons live).
  fromArticleId String
  // The content article shown in the panel.
  toArticleId   String
  // 'guideline' | 'care_plan' | 'action_manual'
  panel         String
  // Order within the panel for this question.
  ordinal       Int    @default(0)

  from WikiArticle @relation("WikiArticleLinkFrom", fields: [fromArticleId], references: [id], onDelete: Cascade)
  to   WikiArticle @relation("WikiArticleLinkTo",   fields: [toArticleId],   references: [id], onDelete: Cascade)

  @@unique([fromArticleId, toArticleId, panel])
  // Backlinks ("appears on N questions") + reverse fork-panel lookups.
  @@index([toArticleId, panel])
  @@index([fromArticleId, panel, ordinal])
}

model WikiSpine {
  id            String @id @default(cuid())
  // e.g. 'elderly-evrat-v4'
  slug          String @unique
  title         String
  programDomain String

  entries WikiSpineEntry[]
  @@index([programDomain])
}

model WikiSpineEntry {
  id           String  @id @default(cuid())
  spineId      String
  ordinal      Int
  articleId    String
  // Null = no header break; otherwise render as section header above this entry.
  sectionLabel String?

  spine   WikiSpine   @relation(fields: [spineId], references: [id], onDelete: Cascade)
  article WikiArticle @relation(fields: [articleId], references: [id])

  @@unique([spineId, ordinal])
  @@index([spineId])
}

// ─── Seeding Fellowships launch portal ──────────────────────────────────────
// Self-contained module (like budget). The Excel "Master Checklist" was the
// living spine; sheets 4-9 and the Gantt were derived views. This portal makes
// the checklist + funnel the living master. Time is measured in weeks from
// Week 0 = 22 Jun 2026; calendar dates derive from SeedingConfig.week0Date.

/// Singleton (id always 1) holding the programme's time anchors.
model SeedingConfig {
  id         Int      @id @default(1)
  week0Date  DateTime // 22 Jun 2026 kickoff
  launchWeek Int      @default(14)
  updatedAt  DateTime @updatedAt
}

/// The 4 Phase-1 geographies (data, not hardcoded — extensible).
model SeedingGeo {
  id        String            @id @default(cuid())
  key       String            @unique // bangalore_urban | odisha | eastern_up | north_east
  label     String
  sortOrder Int               @default(0)
  funnel    SeedingFunnelGeo?
  members   SeedingMember[]
}

/// Top-level workstream (A-E + Launch Gate). Admin add/remove/reorder.
model SeedingWorkstream {
  id         String         @id @default(cuid())
  key        String         @unique // A | B | C | D | E | LAUNCH
  label      String
  color      String         @default("#6366f1")
  sortOrder  Int            @default(0)
  archivedAt DateTime?
  phases     SeedingPhase[]
  tasks      SeedingTask[]
}

/// Grouping level within a workstream (A0, C5, E1, Go-live readiness…).
model SeedingPhase {
  id           String                 @id @default(cuid())
  workstreamId String
  workstream   SeedingWorkstream      @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  label        String
  sortOrder    Int                    @default(0)
  // Which curated Road-to-Launch milestone this phase rolls into (nullable).
  milestoneId  String?
  milestone    SeedingLaunchMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  tasks        SeedingTask[]

  @@index([workstreamId])
  @@index([milestoneId])
}

/// Curated Road-to-Launch milestone — a handful of gates that group phases.
/// Editable in-app; `key` is stable so the importer can re-link phases. The
/// target date is computed from the member phases' latest sub-task due week
/// unless targetWeek is set as an override.
model SeedingLaunchMilestone {
  id         String         @id @default(cuid())
  key        String         @unique
  title      String
  sortOrder  Int            @default(0)
  targetWeek Int?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  phases     SeedingPhase[]
}

enum SeedingTaskStatus {
  not_started
  in_progress
  blocked
  done
}

/// A sub-task on the checklist. Owner is a role label (master tasks stay
/// role-based); "My tasks" maps a member's role+geo to matching tasks.
model SeedingTask {
  id           String            @id @default(cuid())
  workstreamId String
  workstream   SeedingWorkstream @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  phaseId      String?
  phase        SeedingPhase?     @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  code         String? // "01", "C5.1", "E01"
  title        String // Task (col D) — groups its sub-tasks
  detail       String? // deprecated: old single sub-task text; kept for back-compat
  // Task-level fields are ROLLUPS of the sub-tasks (owner = distinct owners,
  // startWeek/dueWeek = min/max, status = aggregate). Editable directly only
  // when the task has no sub-tasks. Maintained by recomputeTaskRollup().
  ownerRole    String? // seeding role vocab label (see lib/seeding/roles.ts)
  supportRoles String?
  startWeek    Int?
  dueWeek      Int?
  dependsOn    String?
  doneMetric   String?
  status       SeedingTaskStatus @default(not_started)
  notes        String? // blocker note when status = blocked
  sortOrder    Int               @default(0)
  createdById  String?
  createdBy    User?             @relation("SeedingTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  archivedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  subtasks     SeedingSubtask[]

  @@index([workstreamId])
  @@index([phaseId])
  @@index([status])
}

/// A sub-task (sheet col E) under a task — the atomic work item, carrying its
/// own owner, window, done-metric and status. The task's fields roll up from
/// these.
model SeedingSubtask {
  id           String            @id @default(cuid())
  taskId       String
  task         SeedingTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  code         String?
  title        String // the sub-task text (col E)
  ownerRole    String?
  supportRoles String?
  startWeek    Int?
  dueWeek      Int?
  dependsOn    String?
  doneMetric   String?
  status       SeedingTaskStatus @default(not_started)
  notes        String?
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([taskId])
}

/// Fixed key dates for the always-visible dashboard rail.
model SeedingMilestone {
  id        String   @id @default(cuid())
  label     String
  date      DateTime
  kind      String? // launch | selection | onboarding | orientation | seed_grant …
  sortOrder Int      @default(0)
}

/// Singleton (id always 1): the funnel "blue cell" assumptions. Targets are
/// computed from these (see lib/seeding/funnel.ts), never stored.
model SeedingFunnelConfig {
  id             Int      @id @default(1)
  fellowsPerGeo  Int      @default(25)
  selectionRatio Int      @default(100) // applications : fellow
  appBufferPct   Float    @default(0.20)
  leadToApp      Float    @default(0.40)
  coldReachToApp Float    @default(0.02)
  reachToLead    Float    @default(0.10)
  shareFromWarm  Float    @default(0.70)
  updatedAt      DateTime @updatedAt
}

/// Editable per-geo actuals (targets are derived, not stored).
model SeedingFunnelGeo {
  id           String     @id @default(cuid())
  geoId        String     @unique
  geo          SeedingGeo @relation(fields: [geoId], references: [id], onDelete: Cascade)
  reachToDate  Int        @default(0)
  leadsToDate  Int        @default(0)
  appsReceived Int        @default(0)
  screened     Int        @default(0)
  shortlisted  Int        @default(0)
  updatedAt    DateTime   @updatedAt
}

/// Who can use the portal + their scope. Central roles have geoId null (all
/// geos); geo roles are scoped to one geography. Role vocab in lib/seeding/roles.ts.
model SeedingMember {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation("SeedingMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  role      String
  geoId     String?
  geo       SeedingGeo? @relation(fields: [geoId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())

  @@unique([userId, role, geoId])
  @@index([userId])
}

// ── Reference tables (seeded from the sheet; read-only pages in v1) ──────────

/// Sheet 12 — Roles, Hires & Responsibilities.
model SeedingRoleDef {
  id                 String  @id @default(cuid())
  role               String
  newHire            String?
  reportsTo          String?
  count              String?
  coreResponsibility String?
  ownsWorkstreams    String?
  inPlaceBy          String?
  sortOrder          Int     @default(0)
}

/// Sheet 10 — Fellowship Execution post-launch arc.
model SeedingExecPhase {
  id         String  @id @default(cuid())
  code       String?
  phase      String
  window     String?
  activities String?
  milestones String?
  quarters   String? // rendered quarter-span label
  sortOrder  Int     @default(0)
}

/// Sheet 11 — Partner-SPOC Interface (provides / spoc / cadence rows).
model SeedingPartnerInterface {
  id        String  @id @default(cuid())
  section   String // provides | spoc | cadence
  colA      String?
  colB      String?
  colC      String?
  colD      String?
  colE      String?
  sortOrder Int     @default(0)
}
