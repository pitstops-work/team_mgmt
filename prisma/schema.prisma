  hhWithConnection       Int     @default(0)
  hhWithoutConnection    Int     @default(0)
  avgHoursPerDay         Float?
  connectionTypes        String? // JSON array
  supplyNature           String? // REGULAR|FREQUENT_CUTS|VERY_UNRELIABLE
  totalStreetlights      Int     @default(0)
  functionalStreetlights Int     @default(0)
  streetlightAdequacy    String? // ADEQUATE|FEW|NONE
  priorityStreets        String?
  remarks                String?

  assessment SettlementAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

// Section 10 — Community Facilities
model FacilitiesBaseline {
  assessmentId      String  @id
  anganwadiCount    Int     @default(0)
  hasSchool         Boolean @default(false)
  hasPHC            Boolean @default(false)
  hasNammaClinic    Boolean @default(false)
  hasRationShop     Boolean @default(false)
  hasCommunityHall  Boolean @default(false)
  hasLibrary        Boolean @default(false)
  hasPark           Boolean @default(false)
  hasPlayground     Boolean @default(false)
  distanceToSchool  Float?
  distanceToHealth  Float?
