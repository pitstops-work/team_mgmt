generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                String    @default("member")
  // Set when this account is the login for a grantee org (role "partner").
  granteeLogin        GrantPartner? @relation("PartnerLogin")
  // Owner = "primordial" super-admin. Asymmetric protection: only the owner
  // can mint new super-admins, and no other super-admin can demote, delete,
  // or reset the password of the owner. Exactly one user should carry this.
  // To transfer or relinquish ownership, do it via direct SQL update.
  isOwner             Boolean   @default(false)
  designation         String    @default("Other") // RP | ZL | PM | Other
  bio                 String?
  notifyDigest        Boolean   @default(false)
  weeklyCapacity      Float     @default(40)
  externalCalendarUrl String?
  lastSeenAt          DateTime?
  // Tenancy (wiki module). Org is required logically but kept nullable here
  // because the seed-wiki script backfills existing users to the "Pitstops
  // Internal" org as a post-migration step.
  orgId               String?
  // Deprecated: previously used for the WhatsApp adapter, which we dropped
  // in favour of email. Columns kept for data preservation — safe to drop in a
  // future migration if confirmed unused.
  phone               String?
  whatsappOptIn       Boolean   @default(true)
  // Wiki email rhythm — opt-out by default. Toggle from /settings/notifications.
  emailOptIn          Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts                  Account[]
  sessions                  Session[]
  goals                     Goal[]
  ownedPitstops             Pitstop[]                      @relation("PitstopOwner")
  programs                  Program[]
  messages                  Message[]
  mentions                  Mention[]
  goalFollows               GoalFollow[]
  threadSubscriptions       ThreadSubscription[]
  notifications             Notification[]
  pushSubscriptions         PushSubscription[]
  createdEvents             PitstopEvent[]                 @relation("PitstopEventCreator")
  lastUpdatedEvents         PitstopEvent[]                 @relation("PitstopEventLastUpdater")
  completedEvents           PitstopEvent[]                 @relation("PitstopEventCompleter")
  eventAttendances          PitstopEventAttendee[]
  leadZones                 Zone[]                         @relation("ZoneLead")
  rpClusters                Cluster[]                      @relation("RPClusters")
  eventFollowups            PitstopEventFollowup[]
  planItems                 PlanItem[]
  // Accountability
  checkins                  PitstopCheckin[]
  retrospectives            Retrospective[]
  standupLogs               StandupLog[]
  // Escalation
  escalationsGiven          PitstopEscalation[]            @relation("EscalatedBy")
  escalationsTaken          PitstopEscalation[]            @relation("EscalatedTo")
  // Co-ownership
  pitstopCoOwners           PitstopCoOwner[]
  goalCoOwners              GoalCoOwner[]
  // Decisions, Audit, Risks
  decisions                 Decision[]
  auditLogs                 AuditLog[]
  risks                     Risk[]
  // Broadcasts & Metrics
  broadcasts                GoalBroadcast[]
  metricDataPoints          MetricDataPoint[]
  // Layer 2 indicator captures
  indicatorCaptures         FacilityIndicatorPoint[]       @relation("IndicatorCapture")
  // Layer 3 journey outcome captures
  journeyOutcomeCaptures    ProgrammeJourneyOutcomePoint[] @relation("JourneyOutcomeCapture")
  closedJourneys            ProgrammeJourney[]             @relation("JourneyClosedBy")
  // Needs assessment
  assessments               SettlementAssessment[]
  // Reporting structure (for notification routing — not a hard gate)
  preferredLang             String                         @default("en")
  reportsToId               String?
  reportsTo                 User?                          @relation("UserReports", fields: [reportsToId], references: [id])
  reports                   User[]                         @relation("UserReports")
  // City assignment (null = sees all cities)
  cityId                    String?
  city                      City?                          @relation("UserCity", fields: [cityId], references: [id], onDelete: SetNull)
  // Verification / confirmation
  verifiedPitstops          Pitstop[]                      @relation("PitstopVerifier")
  confirmedGoals            Goal[]                         @relation("GoalConfirmer")
  dateChanges               PitstopDateChange[]            @relation("DateChanger")
  checklistItems            ChecklistItem[]                @relation("ChecklistItemAssignee")
  lastUpdatedChecklistItems ChecklistItem[]                @relation("ChecklistItemLastUpdater")
  completedChecklistItems   ChecklistItem[]                @relation("ChecklistItemCompleter")
  loginEvents               UserLoginEvent[]
  budgets                   Budget[]                       @relation("BudgetPartner")
  // Tenancy
  org                       Org?                           @relation(fields: [orgId], references: [id], onDelete: SetNull)
  // Wiki module
  ownedWikiPages            WikiPage[]                     @relation("WikiPageOwner")
  editedWikiPages           WikiPage[]                     @relation("WikiPageLastEditor")
  wikiPageVersions          WikiPageVersion[]              @relation("WikiPageVersionEditor")
  wikiComments              WikiComment[]                  @relation("WikiCommentAuthor")
  wikiResolvedComments      WikiComment[]                  @relation("WikiCommentResolver")
  wikiFlags                 WikiFlag[]                     @relation("WikiFlagFlagger")
  wikiReviewCycles          WikiReviewCycle[]              @relation("WikiReviewCycleOwner")
  wikiStaff                 WikiStaff[]                    @relation("WikiStaffUser")
  wikiNotificationLogs      WikiNotificationLog[]
  facilitatedCircles        WikiPracticeCircle[]           @relation("WikiPracticeCircleFacilitator")
  attendedCircles           WikiPracticeCircle[]           @relation("WikiPracticeCircleAttendees")
  attendedPartnerReviews    WikiPartnerReviewMeeting[]     @relation("WikiPartnerReviewMeetingAttendees")
  handoversInitiated        WikiOwnerHandover[]            @relation("WikiHandoverFrom")
  handoversReceived         WikiOwnerHandover[]            @relation("WikiHandoverTo")
  wikiTranslationFlags      WikiTranslationFlag[]
  wikiPageViews             WikiPageView[]
  wikiPracticeGapsFiled     WikiPracticeGap[]              @relation("WikiPracticeGapFiler")
  wikiPracticeGapsAssigned  WikiPracticeGap[]              @relation("WikiPracticeGapAssignee")
  wikiPracticeGapsTriaged   WikiPracticeGap[]              @relation("WikiPracticeGapTriager")
  wikiObservationsRecorded  WikiPracticeObservation[]      @relation("WikiPracticeObservationObserver")
  wikiObservationsAbout     WikiPracticeObservation[]      @relation("WikiPracticeObservationObserved")
  // Response Manual (wiki manual subtype)
  manualSectionsEdited      WikiManualSection[]            @relation("WikiManualSectionEditor")
  manualEntriesObserved     WikiPracticeEntry[]            @relation("WikiPracticeEntryObserver")
  manualEntriesPromoted     WikiPracticeEntry[]            @relation("WikiPracticeEntryPromoter")
  // Wiki articles (v2 — programme-spine reference content; replaces /wiki landing)
  wikiArticlesCreated       WikiArticle[]                  @relation("WikiArticleCreator")
  wikiArticlesUpdated       WikiArticle[]                  @relation("WikiArticleUpdater")
  wikiArticlesArchived      WikiArticle[]                  @relation("WikiArticleArchiver")
  wikiArticleVersionsSaved  WikiArticleVersion[]           @relation("WikiArticleVersionSaver")
  // Action points (visit follow-ups)
  ownedActionPoints         ActionPoint[]                  @relation("ActionPointOwner")
  createdActionPoints       ActionPoint[]                  @relation("ActionPointCreator")
  lastUpdatedActionPoints   ActionPoint[]                  @relation("ActionPointLastUpdater")
  completedActionPoints     ActionPoint[]                  @relation("ActionPointCompleter")
  // Seeding Fellowships launch portal
  seedingMemberships        SeedingMember[]                @relation("SeedingMemberUser")
  seedingTasksCreated       SeedingTask[]                  @relation("SeedingTaskCreatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      GoalStatus @default(Active)
  isTemplate  Boolean    @default(false)
  recurrence  Recurrence @default(None)
  startDate   DateTime?
  targetDate  DateTime?
  closedAt    DateTime?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Confirmation (non-blocking — just records who confirmed and when)
  confirmedById String?
  confirmedAt   DateTime?
  confirmedBy   User?     @relation("GoalConfirmer", fields: [confirmedById], references: [id])

  // Linked facility (for goals managing an existing centre/facility)
  linkedFacilityId String?

  // Needs assessment linkage
  needsDomain       String?
  parameter         Float? // planned headline number for this goal
  outcomeCount      Float? // actual count achieved on completion (if different from parameter)
  needsSettlementId String?
  needsClusterId    String?
  needsZoneId       String?
  needsCityId       String?

  owner           User                    @relation(fields: [ownerId], references: [id])
  pitstops        Pitstop[]
  threads         Thread[]
  attachments     Attachment[]
  followers       GoalFollow[]
  programs        ProgramGoal[]
  // Co-ownership
  coOwners        GoalCoOwner[]
  // Decisions, risks, broadcasts
  decisions       Decision[]
  risks           Risk[]
  broadcasts      GoalBroadcast[]
  // Metrics/KPIs
  metrics         GoalMetric[]
  // Strategic tags
  themes          GoalTheme[]
  quarters        GoalQuarter[]
  // Needs geography
  needsSettlement Settlement?             @relation("GoalNeedsSettlement", fields: [needsSettlementId], references: [id])
  needsCluster    Cluster?                @relation("GoalNeedsCluster", fields: [needsClusterId], references: [id])
  needsZone       Zone?                   @relation("GoalNeedsZone", fields: [needsZoneId], references: [id])
  needsCity       City?                   @relation("GoalNeedsCity", fields: [needsCityId], references: [id])
  linkedFacility  LayerFeature?           @relation("GoalLinkedFacility", fields: [linkedFacilityId], references: [id], onDelete: SetNull)
  // Settlement-level outcome attribution on completion
  outcomes        GoalOutcome[]
  // Layer 3 programme journey phase (this goal fulfilling a phase)
  journeyPhases   ProgrammeJourneyPhase[]
  // Action points (denormalized — always nested under a PitstopEvent under this Goal)
  actionPoints    ActionPoint[]
}

// One row per settlement that received actuals from a completed domain goal.
// Created when a goal is marked Complete — mandatory for domain goals at cluster/zone level.
model GoalOutcome {
  id           String   @id @default(cuid())
  goalId       String
  settlementId String
  count        Int      @default(0)
  createdAt    DateTime @default(now())

  goal       Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([settlementId])
}

model Pitstop {
  id             String            @id @default(cuid())
  title          String
  type           PitstopType       @default(Discussion)
  notes          String?
  status         PitstopStatus     @default(Upcoming)
  priority       PitstopPriority   @default(Medium)
  goalId         String
  ownerId        String?
  ownerInherited Boolean           @default(true)
  customType     String?
  order          Int               @default(0)
  recurrence     PitstopRecurrence @default(None)
  progressTag    String? // Planning | Mobilisation | Setup | Capacity | Engagement | Delivery | Monitoring
  startDate      DateTime?
  targetDate     DateTime?
  completedAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Peer verification (non-blocking — records who verified and when)
  verifiedById String?
  verifiedAt   DateTime?

  // Needs geography (direct FK — single settlement/cluster/zone this pitstop targets)
  needsSettlementId String?
  needsClusterId    String?
  needsZoneId       String?

  // Template provenance — propagated from GoalTemplateDef on apply. Used by
  // the template-sync engine to identify which slot a pitstop maps to so
  // template edits can be retroactively merged into existing goals.
  // Both null = manually created pitstop (sync leaves alone).
  templateSlug String?
  templateKey  String?

  goal            Goal                  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  owner           User?                 @relation("PitstopOwner", fields: [ownerId], references: [id])
  verifiedBy      User?                 @relation("PitstopVerifier", fields: [verifiedById], references: [id])
  threads         Thread[]
  attachments     Attachment[]
  checklistItems  ChecklistItem[]
  blockedBy       PitstopDependency[]   @relation("BlockedPitstop")
  blocking        PitstopDependency[]   @relation("BlockingPitstop")
  reminderLogs    PitstopReminderLog[]
  checkinLog      PitstopCheckinLog?
  events          PitstopEventPitstop[]
  planItems       PlanItemPitstop[]
  // Relations
  coOwners        PitstopCoOwner[]
  escalations     PitstopEscalation[]
  checkins        PitstopCheckin[]
  standupLinks    StandupLogPitstop[]
  risks           Risk[]
  themes          PitstopTheme[]
  dateChanges     PitstopDateChange[]
  // Needs geography relations
  needsSettlement Settlement?           @relation("PitstopNeedsSettlement", fields: [needsSettlementId], references: [id])
  needsCluster    Cluster?              @relation("PitstopNeedsCluster", fields: [needsClusterId], references: [id])
  needsZone       Zone?                 @relation("PitstopNeedsZone", fields: [needsZoneId], references: [id])
  // Action points (denormalized — always nested under a PitstopEvent under this Pitstop)
  actionPoints    ActionPoint[]

  @@index([templateSlug])
}

model ChecklistItem {
  id              String                  @id @default(cuid())
  pitstopId       String
  text            String
  checked         Boolean                 @default(false)
  status          ChecklistItemStatus     @default(NotStarted)
  assigneeId      String?
  lastUpdatedById String?
  completedById   String?
  notes           String?
  completionType  ChecklistCompletionType @default(Activity)
  order           Int                     @default(0)
  // Stable binding identifier propagated from GoalTemplateDef checklist item.
  // Used with templateSlug to look up ActivityIndicatorBinding rows on completion.
  key             String?
  templateSlug    String?
  completedAt     DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  pitstop       Pitstop        @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  assignee      User?          @relation("ChecklistItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  lastUpdatedBy User?          @relation("ChecklistItemLastUpdater", fields: [lastUpdatedById], references: [id])
  completedBy   User?          @relation("ChecklistItemCompleter", fields: [completedById], references: [id])
  activities    PitstopEvent[] @relation("ChecklistActivity")
  threads       Thread[]
  attachments   Attachment[]
}

enum ChecklistItemStatus {
  NotStarted
  Scheduled
  InProgress
  Done
  Blocked
  Rescheduled
  Cancelled
}

enum ChecklistCompletionType {
  Activity
  Voice
  Upload
}

model PitstopDependency {
  id          String @id @default(cuid())
  blockedId   String
  blockedById String

  blocked   Pitstop @relation("BlockedPitstop", fields: [blockedId], references: [id], onDelete: Cascade)
  blockedBy Pitstop @relation("BlockingPitstop", fields: [blockedById], references: [id], onDelete: Cascade)

  @@unique([blockedId, blockedById])
}

model PitstopDateChange {
  id          String   @id @default(cuid())
  pitstopId   String
  field       String   @default("targetDate")
  oldDate     DateTime
  newDate     DateTime
  reason      String?
  changedById String
  createdAt   DateTime @default(now())

  pitstop   Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  changedBy User    @relation("DateChanger", fields: [changedById], references: [id])

  @@index([pitstopId])
}

model Thread {
  id              String    @id @default(cuid())
  name            String
  pitstopId       String?
  goalId          String?
  eventId         String?
  checklistItemId String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  pitstop       Pitstop?             @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  goal          Goal?                @relation(fields: [goalId], references: [id], onDelete: Cascade)
  event         PitstopEvent?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem?       @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)
  messages      Message[]
  subscriptions ThreadSubscription[]
}

model Message {
  id        String    @id @default(cuid())
  body      String
  authorId  String
  threadId  String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  msgType      String  @default("text") // "text" | "voice"
  audioUrl     String?
  originalLang String  @default("en")
  translations Json?

  author      User         @relation(fields: [authorId], references: [id])
  thread      Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  mentions    Mention[]
}

model Attachment {
  id              String         @id @default(cuid())
  name            String
  type            AttachmentType @default(File)
  url             String
  size            Int?
  mimeType        String?
  messageId       String?
  pitstopId       String?
  goalId          String?
  checklistItemId String?
  createdAt       DateTime       @default(now())

  message       Message?       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pitstop       Pitstop?       @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  goal          Goal?          @relation(fields: [goalId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)
}

model Mention {
  id        String   @id @default(cuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model GoalFollow {
  id        String   @id @default(cuid())
  userId    String
  goalId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([userId, goalId])
}

model ThreadSubscription {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
}

// ── Notifications ─────────────────────────────────────────────────────────────

enum NotificationType {
  Mention
  NewPitstop
  GoalStatusChange
  NewMessage
  PitstopStatusChange
  GoalFollowed
  ActivityTagged
  ActivityFollowup
  ActivityMorningNudge
  WeeklyPlanNudge
  CheckinReminder
  EscalationAlert
  BroadcastUpdate
  PitstopVerified
  GoalConfirmed
  WikiFlagCreated
  WikiCommentCreated
  WikiWeeklyDigest
  WikiReviewOverdue
  WikiOwnerTermExpiring
  WikiOwnerTermExpired
  WikiCirclePrompt
  WikiHandoverProposed
  WikiGapAssigned
  WikiGapResolved
  WikiGapPublished
  WikiShadowRecorded
  ActivityRescheduled
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum GoalStatus {
  Active
  Paused
  Complete
}

enum Recurrence {
  None
  Weekly
  Monthly
  Quarterly
  Yearly
}

enum PitstopStatus {
  Upcoming
  InProgress
  Done
}

enum PitstopPriority {
  High
  Medium
  Low
}

enum PitstopType {
  Meeting
  Training
  SiteVisit
  Discussion
  AppDevelopment
  Budgeting
  Proposal
  Research
  Review
  Custom
}

enum AttachmentType {
  File
  Link
}

enum PitstopRecurrence {
  None
  Weekly
  Monthly
  Quarterly
}

enum PitstopEventStatus {
  Scheduled
  Done
  Cancelled
  Rescheduled
  Flagged
}

enum CheckinStatus {
  OnTrack
  AtRisk
  Blocked
  Done
}

enum DecisionStatus {
  Open
  Made
  Reversed
}

enum RiskLikelihood {
  Low
  Medium
  High
}

enum RiskImpact {
  Low
  Medium
  High
}

enum RiskStatus {
  Open
  Mitigated
  Closed
}

enum MetricFrequency {
  Daily
  Weekly
  Monthly
  Quarterly
}

// ── Accountability ────────────────────────────────────────────────────────────

model PitstopCheckin {
  id        String        @id @default(cuid())
  pitstopId String
  userId    String
  date      DateTime      @default(now())
  status    CheckinStatus
  note      String?
  nextSteps String?
  createdAt DateTime      @default(now())

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Retrospective {
  id           String   @id @default(cuid())
  entityType   String // "Goal" | "Pitstop"
  entityId     String
  authorId     String
  wentWell     String?
  couldImprove String?
  keyLearning  String?
  createdAt    DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model StandupLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  yesterday String?
  today     String?
  blockers  String?
  createdAt DateTime @default(now())

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitstops StandupLogPitstop[]
}

model StandupLogPitstop {
  standupLogId String
  pitstopId    String

  standupLog StandupLog @relation(fields: [standupLogId], references: [id], onDelete: Cascade)
  pitstop    Pitstop    @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@id([standupLogId, pitstopId])
}

// ── Escalation ────────────────────────────────────────────────────────────────

model PitstopEscalation {
  id            String    @id @default(cuid())
  pitstopId     String
  escalatedById String
  escalatedToId String
  note          String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  pitstop     Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  escalatedBy User    @relation("EscalatedBy", fields: [escalatedById], references: [id], onDelete: Cascade)
  escalatedTo User    @relation("EscalatedTo", fields: [escalatedToId], references: [id], onDelete: Cascade)
}

// ── Co-ownership ──────────────────────────────────────────────────────────────

model PitstopCoOwner {
  pitstopId String
  userId    String

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pitstopId, userId])
}

model GoalCoOwner {
  goalId String
  userId String

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([goalId, userId])
}

// ── Decision Log ──────────────────────────────────────────────────────────────

model Decision {
  id          String         @id @default(cuid())
  title       String
  description String?
  rationale   String?
  status      DecisionStatus @default(Open)
  decidedAt   DateTime?
  goalId      String?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  goal      Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  createdBy User  @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// ── Audit Trail ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String // "Goal" | "Pitstop" | "User" | "System"
  entityId   String
  userId     String // actor (the user who performed the action)
  action     String // "created" | "updated" | "deleted" | "role_change" | "password_reset" | "password_change" | "portal_access" | ...
  field      String?
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([action, createdAt])
}

// ── Risk Registry ─────────────────────────────────────────────────────────────

model Risk {
  id          String         @id @default(cuid())
  title       String
  description String?
  likelihood  RiskLikelihood @default(Medium)
  impact      RiskImpact     @default(Medium)
  mitigation  String?
  status      RiskStatus     @default(Open)
  goalId      String?
  pitstopId   String?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  goal      Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)
  pitstop   Pitstop? @relation(fields: [pitstopId], references: [id], onDelete: SetNull)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// ── Broadcast Updates ─────────────────────────────────────────────────────────

model GoalBroadcast {
  id        String    @id @default(cuid())
  goalId    String
  authorId  String
  title     String
  body      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  goal   Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ── Metrics / KPIs ────────────────────────────────────────────────────────────

model GoalMetric {
  id          String          @id @default(cuid())
  goalId      String
  name        String
  description String?
  target      Float
  current     Float           @default(0)
  unit        String?
  frequency   MetricFrequency @default(Monthly)
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  goal       Goal              @relation(fields: [goalId], references: [id], onDelete: Cascade)
  dataPoints MetricDataPoint[]
}

model MetricDataPoint {
  id        String   @id @default(cuid())
  metricId  String
  value     Float
  note      String?
  date      DateTime
  userId    String
  createdAt DateTime @default(now())

  metric GoalMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Layer 2: Facility / Settlement Indicators ────────────────────────────────
// Ongoing state of community facilities/services — enrollment %, attendance,
// downtime, saturation %. Distinct from Layer 1 (needs remaining, fixed
// baseline) and from goal-scoped GoalMetric. Sourced from MIS APIs, RP activity
// completions, or manual admin entry — all config-driven, no hardcoding.

enum FacilityIndicatorSource {
  MIS_API
  RP_ACTIVITY
  MANUAL_ADMIN
}

model FacilityIndicatorDef {
  id               String          @id @default(cuid())
  key              String          @unique // e.g. "creche_enrollment_pct"
  label            String
  description      String?
  domain           String // links to NeedsFormulaConfig.domain
  facilityLayerKey String? // links to FacilityLayerConfig.layerKey (optional narrowing)
  schemeId         String? // links to EntitlementScheme (optional)
  unit             String? // "%", "count", "litres", etc.
  frequency        MetricFrequency @default(Monthly)
  color            String          @default("#6366f1")

  // Target — nullable for trend-only indicators. JSON describes how to compute:
  // { type: "fixed", value: number }
  // { type: "settlement_field", field: string, multiplier: number }
  // { type: "facility_count", multiplier: number }
  // { type: "scheme_baseline", multiplier: number }
  targetFormula Json?

  // Capture source (mutually exclusive — drives which fields below matter)
  captureSource  FacilityIndicatorSource
  // MIS_API path
  misProviderId  String?
  misFetchConfig Json? // provider-specific, e.g. { endpoint, valuePath, settlementCodePath, filters }
  // RP_ACTIVITY path: see ActivityIndicatorBinding (separate table — many bindings possible)

  // Staleness lens — same UX as Layer 1
  staleYellowDays Int @default(45)
  staleRedDays    Int @default(90)

  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  misProvider      MISProviderConfig?         @relation(fields: [misProviderId], references: [id], onDelete: SetNull)
  scheme           EntitlementScheme?         @relation("IndicatorScheme", fields: [schemeId], references: [id], onDelete: SetNull)
  indicators       FacilityIndicator[]
  activityBindings ActivityIndicatorBinding[]
}

model FacilityIndicator {
  id             String                   @id @default(cuid())
  defId          String
  settlementId   String
  currentValue   Float?
  targetValue    Float? // snapshot at last capture
  lastCapturedAt DateTime?
  lastSource     FacilityIndicatorSource?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  def        FacilityIndicatorDef     @relation(fields: [defId], references: [id], onDelete: Cascade)
  settlement Settlement               @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  points     FacilityIndicatorPoint[]

  @@unique([defId, settlementId])
  @@index([settlementId])
}

model FacilityIndicatorPoint {
  id           String                  @id @default(cuid())
  indicatorId  String
  value        Float
  targetValue  Float? // snapshot at capture time
  capturedAt   DateTime
  source       FacilityIndicatorSource
  sourceRefId  String? // PitstopEvent.id, MIS sync log id, etc.
  note         String?
  capturedById String?
  createdAt    DateTime                @default(now())

  indicator  FacilityIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  capturedBy User?             @relation("IndicatorCapture", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([indicatorId, capturedAt])
}

model MISProviderConfig {
  id             String    @id @default(cuid())
  key            String    @unique // "frappe-creche-mis"
  label          String
  baseUrl        String
  authType       String    @default("frappe") // "frappe" | "api_key" | "basic" | "bearer"
  // Credentials kept behind admin auth — provider-specific JSON
  // e.g. frappe: { apiKey, apiSecret } ; bearer: { token } ; basic: { user, pass }
  credentials    Json?
  isActive       Boolean   @default(true)
  lastSyncedAt   DateTime?
  lastSyncStatus String? // "ok" | "error: <msg>"
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  indicators FacilityIndicatorDef[]
  syncLogs   MISProviderSyncLog[]
}

model MISProviderSyncLog {
  id            String    @id @default(cuid())
  providerId    String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String // "running" | "ok" | "error"
  pointsWritten Int       @default(0)
  message       String?
  details       Json?

  provider MISProviderConfig @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, startedAt])
}

// Binds a checklist item (in a template) to an indicator — when an RP completes
// that activity, a FacilityIndicatorPoint is written from a numeric form field.
model ActivityIndicatorBinding {
  id           String   @id @default(cuid())
  defId        String
  templateSlug String // GoalTemplateDef.slug
  checklistKey String // slugified text of the checklist item (stable enough for v1)
  numericField String   @default("value") // form field name expected on the activity completion payload
  createdAt    DateTime @default(now())

  def FacilityIndicatorDef @relation(fields: [defId], references: [id], onDelete: Cascade)

  @@unique([defId, templateSlug, checklistKey])
  @@index([templateSlug, checklistKey])
}

// ── Themes ────────────────────────────────────────────────────────────────────

model Theme {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  goals    GoalTheme[]
  pitstops PitstopTheme[]
}

model PitstopTheme {
  pitstopId String
  themeId   String

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
  theme   Theme   @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([pitstopId, themeId])
}

model GoalTheme {
  goalId  String
  themeId String

  goal  Goal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([goalId, themeId])
}

// ── Geography: City → Zone → Cluster → Settlement ────────────────────────────

model City {
  id               String    @id @default(cuid())
  name             String
  totalSettlements Int       @default(0)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())

  zones       Zone[]
  settlements Settlement[]
  needsGoals  Goal[]       @relation("GoalNeedsCity")
  users       User[]       @relation("UserCity")
}

// Polygon for this zone is derived live by the `zone_geometry` view
// (ST_Union of every settlement's polygon + 300m buffer around
// centroid-only settlements). See migration
// 20260605010000_derived_cluster_zone_views.
model Zone {
  id        String    @id @default(cuid())
  name      String
  cityId    String?
  leadId    String?
  color     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  city          City?                @relation(fields: [cityId], references: [id], onDelete: SetNull)
  lead          User?                @relation("ZoneLead", fields: [leadId], references: [id], onDelete: SetNull)
  clusters      Cluster[]
  needsGoals    Goal[]               @relation("GoalNeedsZone")
  needsPitstops Pitstop[]            @relation("PitstopNeedsZone")
  layerFeatures LayerFeature[]
  wikiCircles   WikiPracticeCircle[]
}

// Polygon for this cluster is derived live by the `cluster_geometry`
// view (ST_Union of its settlements' polygons + 300m buffer around
// centroid-only settlements). See migration
// 20260605010000_derived_cluster_zone_views.
model Cluster {
  id              String    @id @default(cuid())
  name            String
  zoneId          String
  color           String?
  label           String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  isHealthCluster Boolean   @default(false)
  // Partner that runs this cluster. Added 2026-06-04 as part of the Org
  // migration — previously inferred from each settlement's partner.
  partnerOrgId    String?

  zone          Zone           @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  settlements   Settlement[]
  needsGoals    Goal[]         @relation("GoalNeedsCluster")
  needsPitstops Pitstop[]      @relation("PitstopNeedsCluster")
  layerFeatures LayerFeature[]
  rps           User[]         @relation("RPClusters")
  partnerOrg    Org?           @relation("ClusterPartnerOrg", fields: [partnerOrgId], references: [id], onDelete: SetNull)

  @@index([partnerOrgId])
}

model LayerFeature {
  id           String   @id @default(cuid())
  name         String
  layerKey     String // creches | children_centres | youth_centres | resource_centres
  centreType   String?
  // Legacy free-text partner identifier (e.g. "CFAR Creches", "actionaid").
  // Kept during the Org migration so backfill can resolve to partnerOrgId.
  // To be dropped once partnerOrg is fully populated.
  partner      String?
  // Partner-org FK (added 2026-06-04). Backfilled from `partner` free-text.
  partnerOrgId String?
  lat          Float
  lng          Float
  settlementId String?
  clusterId    String?
  zoneId       String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settlement  Settlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)
  cluster     Cluster?    @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  zone        Zone?       @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  linkedGoals Goal[]      @relation("GoalLinkedFacility")
  partnerOrg  Org?        @relation("LayerFeaturePartnerOrg", fields: [partnerOrgId], references: [id], onDelete: SetNull)

  @@index([partnerOrgId])
}

model Settlement {
  id        String    @id @default(cuid())
  name      String
  clusterId String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Geospatial
  polygon     Json?
  centroidLat Float?
  centroidLng Float?

  // City direct FK — denormalised for fast city-scoped queries (backfilled from cluster→zone→city)
  cityId String?

  // Partner organisation (1:1 — one partner covers this settlement). Legacy
  // MapPartner FK kept during the Org migration; new code reads partnerOrg.
  partnerId    String?
  partnerOrgId String?

  cluster            Cluster                  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  city               City?                    @relation(fields: [cityId], references: [id])
  partner            MapPartner?              @relation(fields: [partnerId], references: [id])
  partnerOrg         Org?                     @relation("SettlementPartnerOrg", fields: [partnerOrgId], references: [id], onDelete: SetNull)
  assessments        SettlementAssessment[]
  profile            SettlementProfile?
  note               SettlementNote?
  civicData          SettlementCivicData?
  // Needs geography back-relations
  needsGoals         Goal[]                   @relation("GoalNeedsSettlement")
  needsPitstops      Pitstop[]                @relation("PitstopNeedsSettlement")
  goalOutcomes       GoalOutcome[]
  schools            SettlementSchool[]
  healthCentres      SettlementHealthCentre[]
  layerFeatures      LayerFeature[]
  // Layer 2 facility indicators
  facilityIndicators FacilityIndicator[]
  // Layer 3 programme journeys
  programmeJourneys  ProgrammeJourney[]

  @@index([partnerOrgId])
}

// Government / programme health centre
model HealthCentre {
  id         String   @id @default(cuid())
  name       String
  lat        Float
  lng        Float
  centreType String // CRC | Foundation Health Centre | Government Health Centre | Referral Helpdesk Hospital | Super Speciality Hospital
  notes      String?
  createdAt  DateTime @default(now())

  settlements SettlementHealthCentre[]
}

// Junction: settlement ↔ health centre with haversine distance
model SettlementHealthCentre {
  id             String @id @default(cuid())
  settlementId   String
  healthCentreId String
  distanceKm     Float

  settlement   Settlement   @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  healthCentre HealthCentre @relation(fields: [healthCentreId], references: [id], onDelete: Cascade)

  @@unique([settlementId, healthCentreId])
}

// Government school mapped to nearby settlements
model School {
  id         String   @id @default(cuid())
  name       String
  lat        Float
  lng        Float
  address    String?
  gmapsId    String?  @unique
  schoolType String   @default("Government")
  createdAt  DateTime @default(now())

  settlements SettlementSchool[]
}

// Junction: settlement ↔ school with computed distance
model SettlementSchool {
  id           String @id @default(cuid())
  settlementId String
  schoolId     String
  distanceKm   Float

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([settlementId, schoolId])
}

// Flattened snapshot of the latest SettlementAssessment for fast reads
model SettlementProfile {
  settlementId         String    @id
  totalHouseholds      Int       @default(0)
  children6m3yr        Int       @default(0)
  children4to14        Int       @default(0)
  youth15to21          Int       @default(0)
  elderly60plus        Int       @default(0)
  settlementType       String?
  priorityIssues       String?
  // Addressable need snapshot (latest assessment)
  addressableCreches   Int?
  addressableToilets   Int?
  addressableWaterATMs Int?
  lastAssessmentId     String?
  lastSyncedAt         DateTime?
  updatedAt            DateTime  @updatedAt

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
}

// ── Quarterly Planning ────────────────────────────────────────────────────────

model Quarter {
  id        String    @id @default(cuid())
  year      Int
  quarter   Int // 1–4
  startDate DateTime
  endDate   DateTime
  focus     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  goals GoalQuarter[]

  @@unique([year, quarter])
}

model GoalQuarter {
  goalId    String
  quarterId String

  goal    Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  quarter Quarter @relation(fields: [quarterId], references: [id], onDelete: Cascade)

  @@id([goalId, quarterId])
}

// ── Legacy / Utility ──────────────────────────────────────────────────────────

model CustomPitstopType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model PitstopReminderLog {
  id        String   @id @default(cuid())
  pitstopId String
  type      String // "10d" | "3d" | "due"
  sentAt    DateTime @default(now())

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([pitstopId, type])
}

model PitstopCheckinLog {
  id         String   @id @default(cuid())
  pitstopId  String   @unique
  lastSentAt DateTime

  pitstop Pitstop @relation(fields: [pitstopId], references: [id], onDelete: Cascade)
}

enum PitstopEventType {
  Meeting
  Visit
  Event
}

model PitstopEvent {
  id                   String             @id @default(cuid())
  title                String
  description          String?
  type                 PitstopEventType   @default(Meeting)
  status               PitstopEventStatus @default(Scheduled)
  scheduledAt          DateTime
  // Frozen at creation, never mutated by reschedule. Delay/SLA are always
  // computed from this date so reschedule cannot launder lateness.
  originalScheduledAt  DateTime
  // Transient "also show this activity on this day's Today list" override.
  // Set by Add-to-today (overdue or future pull-forward). Never changes
  // scheduledAt — purely additive for list visibility. Old values are harmless
  // because the Today query only matches when displayDate equals today.
  displayDate          DateTime?
  endsAt               DateTime?
  location             String?
  createdById          String
  lastUpdatedById      String?
  completedById        String?
  checklistItemId      String?
  rescheduledFrom      DateTime?
  rescheduleReason     String?
  rescheduleReasonCode String?
  rescheduleCount      Int                @default(0)
  cancellationReason   String?
  completedAt          DateTime?
  deletedAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Template provenance — slugified from the template activity's title.
  // templateSlug rides on the parent ChecklistItem (no need to duplicate).
  // Null = manually scheduled activity (sync leaves alone).
  templateKey String?

  createdBy     User                   @relation("PitstopEventCreator", fields: [createdById], references: [id])
  lastUpdatedBy User?                  @relation("PitstopEventLastUpdater", fields: [lastUpdatedById], references: [id])
  completedBy   User?                  @relation("PitstopEventCompleter", fields: [completedById], references: [id])
  checklistItem ChecklistItem?         @relation("ChecklistActivity", fields: [checklistItemId], references: [id], onDelete: SetNull)
  attendees     PitstopEventAttendee[]
  pitstops      PitstopEventPitstop[]
  followups     PitstopEventFollowup[]
  threads       Thread[]
  // Action points raised from this activity
  actionPoints  ActionPoint[]

  // Activities-page + planner queries sort + range-filter on scheduledAt.
  // Partial index (active + non-cancelled) backs the most common UI filter.
  // Full index covers the rest (calendar feed, admin views, audit lookups).
  // See migration 20260604120000_pitstop_event_perf_indexes for the partial
  // index — Prisma can't express WHERE predicates in @@index so it lives
  // only in the migration SQL.
  @@index([scheduledAt])
}

model PitstopEventFollowup {
  id          String                      @id @default(cuid())
  eventId     String
  userId      String
  response    PitstopEventFollowupStatus?
  sentAt      DateTime
  nudgeSentAt DateTime?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  event PitstopEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

enum PitstopEventFollowupStatus {
  Done
  No
  Cancelled
  Rescheduled
}

model PitstopEventAttendee {
  id      String @id @default(cuid())
  eventId String
  userId  String
  status  String @default("accepted") // accepted | pending | declined

  event PitstopEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model PitstopEventPitstop {
  id        String @id @default(cuid())
  eventId   String
  pitstopId String

  event   PitstopEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pitstop Pitstop      @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([eventId, pitstopId])
}

model Program {
  id          String    @id @default(cuid())
  title       String
  description String?
  ownerId     String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner User          @relation(fields: [ownerId], references: [id])
  goals ProgramGoal[]
}

model ProgramGoal {
  id        String @id @default(cuid())
  programId String
  goalId    String

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  goal    Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([programId, goalId])
}

model PlanItem {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  type        String    @default("Note")
  userId      String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pitstops PlanItemPitstop[]
}

model PlanItemPitstop {
  id         String @id @default(cuid())
  planItemId String
  pitstopId  String

  planItem PlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  pitstop  Pitstop  @relation(fields: [pitstopId], references: [id], onDelete: Cascade)

  @@unique([planItemId, pitstopId])
}

model AppSetting {
  key   String @id
  value String
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Urban Programme Map ───────────────────────────────────────────────────────

model SettlementNote {
  settlementId String   @id
  note         String   @default("")
  updatedAt    DateTime @updatedAt

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
}

model MapPartner {
  id           String   @id @default(cuid())
  key          String   @unique
  label        String
  color        String   @default("#6366f1")
  contactName  String?
  contactPhone String?
  notes        String?
  isBuiltIn    Boolean  @default(false)
  createdAt    DateTime @default(now())

  settlements Settlement[]
}

// ── Needs Assessment ──────────────────────────────────────────────────────────

// NeedsDomain is no longer an enum — domain keys are stored as plain strings
// and configured via NeedsFormulaConfig (admin-editable from /settings/needs)

// Admin-configurable formula denominators per domain
model NeedsFormulaConfig {
  domain            String   @id
  /// numerator in "X units per N people". 1 for the legacy single-unit ratio.
  numerator         Float    @default(1)
  denominator       Float?
  description       String?
  label             String?
  color             String   @default("#6b7280")
  domainType        String   @default("count") // "count" | "boolean" | "entitlement" | "civic"
  populationField   String? // "totalHouseholds" | "children6m3yr" | "youth15to21" | "elderly60plus" etc.
  assessmentColumn  String? // column name in SettlementAssessment for "existing" count, e.g. "existingCreches"
  addressableColumn String? // column name in SettlementAssessment for "addressable need", e.g. "addressableCreches"
  civicGroup        String? // for domainType="civic": "borewell" | "toiletConnection" | "toiletFacility" | "waterSupply"
  civicWeightGroup  String? // for domainType="count": multiply populationField by this civic group's need score before dividing by denominator
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  clusterScope      Boolean  @default(false) // legacy — superseded by assessmentLevel
  assessmentLevel   String   @default("settlement") // "settlement" | "cluster" | "zone" | "city"
  linkedSchemeId    String? // for domainType="entitlement" — links to an EntitlementScheme
  staleYellowDays   Int      @default(60) // days since last delivery before showing yellow staleness signal
  staleRedDays      Int      @default(120) // days since last delivery before showing red staleness signal
  updatedAt         DateTime @updatedAt

  linkedScheme EntitlementScheme? @relation("DomainScheme", fields: [linkedSchemeId], references: [id], onDelete: SetNull)
}

// Civic amenity data per settlement from Janadhikara survey
// All % values are per-household percentages (0-100)
model SettlementCivicData {
  settlementId         String   @id
  janaId               Int? // janadhikara slum_id for future syncs
  borewell             Json? // { individual, public, shared, privateTanker, na } — all % of HH
  toiletConnection     Json? // { sewerage, soakPit, noSewerage }
  toiletFacility       Json? // { individual, shared, public, publicPaid, noFacility }
  waterSupply          Json? // { individual, shared, public, privateTanker }
  // Pre-computed need scores (0-100, higher = more need) for aggregation
  borewellNeedScore    Float? // 100 - individual%
  toiletConnNeedScore  Float? // soakPit% + noSewerage%
  toiletFacNeedScore   Float? // 100 - individual%
  waterSupplyNeedScore Float? // 100 - individual%
  syncedAt             DateTime @default(now())

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
}

// Entitlement schemes (hierarchical — BoCW parent + 14 children)
model EntitlementScheme {
  id          String   @id @default(cuid())
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  parent        EntitlementScheme?     @relation("SchemeHierarchy", fields: [parentId], references: [id])
  children      EntitlementScheme[]    @relation("SchemeHierarchy")
  baselines     EntitlementBaseline[]
  linkedDomains NeedsFormulaConfig[]   @relation("DomainScheme")
  indicators    FacilityIndicatorDef[] @relation("IndicatorScheme")
}

// One row per survey per settlement — versioned (history preserved)
model SettlementAssessment {
  id             String   @id @default(cuid())
  settlementId   String
  assessmentYear Int
  assessedById   String
  assessedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  // Population (drives target calculations)
  totalHouseholds Int @default(0)
  children6m3yr   Int @default(0)
  children4to14   Int @default(0)
  youth15to21     Int @default(0)
  elderly60plus   Int @default(0)

  // Existing infrastructure (gap = target − existing − apf_actuals)
  existingCreches                Int @default(0)
  existingChildrenCentres        Int @default(0)
  existingYouthGroups            Int @default(0)
  existingYouthResourceCentres   Int @default(0)
  existingElderlyKitchens        Int @default(0)
  existingElderlyCentres         Int @default(0)
  existingPalliativeUnits        Int @default(0)
  existingPalliativeCareServices Int @default(0)
  existingReferralSystems        Int @default(0)
  existingCommunityToilets       Int @default(0)
  existingWaterATMs              Int @default(0)

  // Addressable need — field-verified, feasibility-filtered demand
  addressableCreches   Int?
  addressableToilets   Int?
  toiletLandAvailable  Boolean?
  toiletLandType       String? // "Govt" | "Private"
  addressableWaterATMs Int?
  waterATMCurrentCount Int?
  waterATMFeasible     Boolean?

  // Settlement profile (Section 2)
  settlementType    String?
  composition       String?
  predominantGroups String?
  languages         String?
  yearsEstablished  Int?

  // Land & Tenure (Section 3)
  landOwnership      String?
  legalStatus        String?
  hakkupatraEligible Int?

  // Priority issues & notes (Sections 11–12)
  priorityIssues  String?
  enumeratorNotes String?

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  assessedBy User       @relation(fields: [assessedById], references: [id])

  // Civic baseline sections (1-to-1 per assessment)
  roads         RoadBaseline?
  water         WaterBaseline?
  sanitation    SanitationBaseline?
  drainageSewer DrainageSewerBaseline?
  drainageStorm DrainageStormBaseline?
  waste         WasteBaseline?
  electricity   ElectricityBaseline?
  facilities    FacilitiesBaseline?
  safety        SafetyBaseline?

  entitlements EntitlementBaseline[]

  @@index([settlementId, assessedAt])
}

// Section 4 — Roads
model RoadBaseline {
  assessmentId   String  @id
  roadType       String? // CONCRETE|GRAVEL|MUD|NONE
  condition      String? // GOOD|DAMAGED|VERY_POOR
  accessibility  String? // MOTORABLE|TWO_WHEELER|PEDESTRIAN
  unusableInRain Boolean @default(false)
  remarks        String?

  assessment SettlementAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

// Section 5 — Water
model WaterBaseline {
  assessmentId         String  @id
  drinkingSource       String? // PIPED|PUBLIC_TAP|BOREWELL|TANKER|PACKAGED|OTHER
  treatsDrinkingWater  Boolean @default(false)
  treatmentMethod      String?
  waterQuality         String? // GOOD|ACCEPTABLE|POOR
  poorQualityReason    String?
  nonPotableSource     String?
  nonPotableSufficient Boolean @default(true)
  nonPotableIssues     String?
  remarks              String?

  assessment SettlementAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

// Section 6 — Sanitation
model SanitationBaseline {
  assessmentId         String  @id
  individualToiletPct  Float   @default(0)
  sharedToiletPct      Float   @default(0)
  openDefecationPct    Float   @default(0)
  communityToiletCount Int     @default(0)
  toiletSeats          Int     @default(0)
  bathCount            Int     @default(0)
  urinalCount          Int     @default(0)
  toiletsPaid          Boolean @default(false)
  toiletFee            Float?
  toiletCondition      String? // GOOD|FAIR|POOR|NOT_USABLE
  toiletsSufficient    Boolean @default(false)
  sewerConnection      String? // SEWER_LINE|SEPTIC_TANK|OPEN_DRAIN|NONE
  blockageFrequency    String? // FREQUENTLY|OCCASIONALLY|NO_ISSUES
  bathingFacilities    String? // ADEQUATE|LIMITED|NONE
  remarks              String?

  assessment SettlementAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

// Section 7A — Sewer/Wastewater Drainage
model DrainageSewerBaseline {
  assessmentId      String  @id
  disposalType      String? // UNDERGROUND|SEPTIC_INDIVIDUAL|SEPTIC_SHARED|OPEN_DRAINS|NONE
  coverage          String? // MOST|SOME|VERY_FEW|NONE
  condition         String? // GOOD|NEEDS_REPAIR|POOR
  issues            String? // JSON array
  blockageFrequency String? // FREQUENTLY|OCCASIONALLY|RARE
  safeDisposal      Boolean @default(false)
  remarks           String?

  assessment SettlementAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

// Section 7B — Storm Water Drainage
model DrainageStormBaseline {
  assessmentId       String  @id
  drainType          String? // COVERED|OPEN|MIXED|NONE
  drainCondition     String? // CLEAN|PARTIALLY_CLOGGED|FULLY_CLOGGED|DAMAGED
  connectivity       String? // WELL_CONNECTED|PARTIALLY|NOT_CONNECTED
  floodingOccurs     Boolean @default(false)
  floodFrequency     String? // EVERY_RAIN|HEAVY_ONLY|OCCASIONALLY
  floodLevel         String? // ANKLE|KNEE|ABOVE_KNEE
