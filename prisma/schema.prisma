  remarks           String?

  assessment SettlementAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

// Section 11 — Safety
model SafetyBaseline {
  assessmentId       String  @id
  blindSpotsCount    Int     @default(0)
  blindSpotTypes     String? // JSON array
  activitiesObserved String? // JSON array
  remarks            String?

  assessment SettlementAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

// Entitlement tracking per scheme per assessment
model EntitlementBaseline {
  id                 String  @id @default(cuid())
  assessmentId       String
  schemeId           String
  eligibleHouseholds Int     @default(0)
  enrolledHouseholds Int     @default(0) // NGO-assisted enrollments (from scheme_report / Frappe)
  surveyEnrolled     Int? // Pre-existing at survey time (from Janadhikara household survey XLSX)
  notes              String?

  assessment SettlementAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  scheme     EntitlementScheme    @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, schemeId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model GoalTemplateDef {
  id                     String   @id @default(cuid())
  slug                   String   @unique
  name                   String
  description            String   @default("")
  category               String
  icon                   String   @default("🎯")
  needsDomain            String?
  linkedFacilityLayerKey String? // e.g. "creches" | "children_centres" | "youth_centres" — shows facility picker on goal creation
  sortOrder              Int      @default(0)
  parameters             Json     @default("[]")
  pitstops               Json     @default("[]")
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
