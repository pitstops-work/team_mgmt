// ─── Budget Tool ──────────────────────────────────────────────────────────────

// BudgetDomain is no longer an enum — domain keys are plain strings
// configured via BudgetDomainConfig (admin-editable from /admin).

model BudgetDomainConfig {
  id               String   @id @default(cuid())
  city             String   @default("Bangalore")
  key              String // stored in domain fields, e.g. "Children"
  label            String // display name, e.g. "Elderly + Community Kitchen"
  description      String?
  position         Int      @default(0)
  isActive         Boolean  @default(true)
  // For per-beneficiary cost analysis
  beneficiaryLabel String? // e.g. "Children", "Youth enrolled"
  beneficiaryVar   String? // programme input key: "nCLCs", "nElderly", "nCreches", "nSettlements"
  beneficiaryMult  Float    @default(1) // multiply beneficiaryVar by this
  createdAt        DateTime @default(now())

  @@unique([city, key])
  @@index([city, position])
}

enum BudgetStatus {
  draft
  final
  approved
}

enum ReportFrequency {
  monthly
  bi_monthly
  quarterly
  half_yearly
  annual
}

enum ReportSlotStatus {
  pending
  submitted
  under_review
  sent_back
  approved
}

enum ReallocationStatus {
  pending
  approved
  rejected
}

enum ReallocationDuration {
  remaining_year
  full_grant
  custom
  one_time
}

enum InflationType {
  Salary
  Other
  Nil
}

enum BudgetSection {
  salary
  capex
  travel
  programme
  admin_salary
  admin_other
  additional
}

model Budget {
  id           String              @id @default(cuid())
  name         String
  partnerId    String
  partner      User                @relation("BudgetPartner", fields: [partnerId], references: [id])
  domains      String[]
  city         String              @default("Bangalore")
  years        Int                 @default(1)
  status       BudgetStatus        @default(draft)
  inputs       BudgetInputs?
  lines        BudgetLine[]
  reportConfig BudgetReportConfig?
  reportSlots  BudgetReportSlot[]
  reports      BudgetReport[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([partnerId])
}

model BudgetInputs {
  id                        String @id @default(cuid())
  budgetId                  String @unique
  budget                    Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  nSettlements              Int    @default(0)
  nClusters                 Int    @default(0)
  nCLCs                     Int    @default(0)
  clcRentPerMonth           Int    @default(0)
  nYRCs                     Int    @default(0)
  yrcRentPerMonth           Int    @default(0)
  nElderlyCentres           Int    @default(0)
  nElderly                  Int    @default(0)
  elderlyCentreRentPerMonth Int    @default(0)
  cosPerCluster             Int    @default(2)
  rcRentPerMonth            Int    @default(0)
  nCreches                  Int    @default(0)
  crecheRentPerMonth        Int    @default(0)
  extraInputs               Json   @default("{}") // custom programme inputs added via admin
}

model BudgetLine {
  id                       String                      @id @default(cuid())
  budgetId                 String
  budget                   Budget                      @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  domain                   String?
  section                  BudgetSection
  position                 Int
  description              String
  costCategory             InflationType
  unitType                 String                      @default("")
  isAutoGenerated          Boolean                     @default(true)
  salaryHint               String?
  notes                    String?
  y1Units                  Float                       @default(0)
  y1UnitCost               Float                       @default(0)
  y1AllocPct               Float                       @default(1)
  y1Total                  Float                       @default(0)
  y2Units                  Float                       @default(0)
  y2UnitCost               Float                       @default(0)
  y2AllocPct               Float                       @default(1)
  y2Total                  Float                       @default(0)
  y3Units                  Float                       @default(0)
  y3UnitCost               Float                       @default(0)
  y3AllocPct               Float                       @default(1)
  y3Total                  Float                       @default(0)
  isReallocation           Boolean                     @default(false)
  sourceReallocationId     String?
  reportLines              BudgetReportLine[]
  reallocationRequestsFrom BudgetReallocationRequest[] @relation("ReallocationFrom")
  reallocationRequestsTo   BudgetReallocationRequest[] @relation("ReallocationTo")

  @@index([budgetId, position])
}

model BudgetReportConfig {
  id             String          @id @default(cuid())
  budgetId       String          @unique
  budget         Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  frequency      ReportFrequency
  grantStartDate DateTime
  grantEndDate   DateTime
  dueAfterDays   Int             @default(30)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model BudgetReportSlot {
  id         String           @id @default(cuid())
  budgetId   String
  budget     Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  slotNumber Int
  grantYear  Int
  periodFrom DateTime
  periodTo   DateTime
  dueDate    DateTime
  status     ReportSlotStatus @default(pending)
  report     BudgetReport?
  createdAt  DateTime         @default(now())

  @@unique([budgetId, slotNumber])
  @@index([budgetId, grantYear])
}

model BudgetReport {
  id                   String                      @id @default(cuid())
  slotId               String                      @unique
  slot                 BudgetReportSlot            @relation(fields: [slotId], references: [id], onDelete: Cascade)
  budgetId             String
  budget               Budget                      @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  openingBalance       Float                       @default(0)
  tranchesReceived     Float                       @default(0)
  interestEarned       Float                       @default(0)
  bankBalance          Float                       @default(0)
  fdBalance            Float                       @default(0)
  cashInHand           Float                       @default(0)
  advances             Float                       @default(0)
  receivables          Float                       @default(0)
  payables             Float                       @default(0)
  bankStatementUrl     String?
  bankStatementParsed  Json?
  partnerNotes         String?
  reviewerNotes        String?
  submittedAt          DateTime?
  approvedAt           DateTime?
  lines                BudgetReportLine[]
  reallocationRequests BudgetReallocationRequest[]
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([budgetId])
}

model BudgetReallocationRequest {
  id              String               @id @default(cuid())
  reportId        String
  report          BudgetReport         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fromLineId      String
  fromLine        BudgetLine           @relation("ReallocationFrom", fields: [fromLineId], references: [id])
  toLineId        String?
  toLine          BudgetLine?          @relation("ReallocationTo", fields: [toLineId], references: [id])
  toDescription   String?
  toSection       BudgetSection?
  requestedAmount Float
  isRecurring     Boolean              @default(false)
  monthlyAmount   Float                @default(0)
  durationType    ReallocationDuration
  durationMonths  Int?
  rationale       String
  sourceUnspent   Float                @default(0)
  willSustain     Boolean              @default(true)
  sustainNote     String?
  status          ReallocationStatus   @default(pending)
  approvedAmount  Float?
  reviewerComment String?
  resolvedAt      DateTime?
  createdLineId   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([reportId])
  @@index([fromLineId])
}

model BudgetReportLine {
  id           String       @id @default(cuid())
  reportId     String
  report       BudgetReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  budgetLineId String
  budgetLine   BudgetLine   @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  actualAmount Float        @default(0)
  notes        String?

  @@unique([reportId, budgetLineId])
  @@index([reportId])
}

model CostRegistry {
  id            String   @id @default(cuid())
  city          String   @default("Bangalore")
  domain        String?
  itemKey       String
  unitCost      Float
  unit          String
  effectiveYear Int      @default(2025)
  notes         String?
  displayGroup  String? // for inp.* items: "geography" | "facilities" | "coverage"; null → coverage
  needsDomain   String? // for inp.* items: links to NeedsFormulaConfig.domain for scenario loading
  updatedAt     DateTime @updatedAt

  @@unique([city, itemKey])
}

// Each row is one generated line in a budget.
// The formula fields fully describe how to compute unitCount and unitCost
// from programme inputs (nCLCs, nCreches, etc.) and the cost registry.
//
// Unit count:
//   inputVar     – which programme input scales this line
//                  "fixed_1"|"fixed_12"|"nCLCs"|"nYRCs"|"nSettlements"|
//                  "nClusters"|"nElderly"|"nElderlyCentres"|"nCreches"|"cosTotal"
//   inputMonthly – multiply by 12 (monthly → annual)
//   supervisorRatioKey – if set: units = ceil(inp[inputVar] / reg[key]) × 12
//
// Unit cost (evaluated in order – first matching rule wins):
//   isSalaryStub   – cost = 0 (user fills salary)
//   userInputCost  – cost = programme input field (rent entered by user)
//   costPctOf      – cost = reg[costPctOf] × costPct / 100
//   workerRatioKey – cost = reg[wKey] × reg[costKey] × 12 × (1 + reg[bufferKey]/100)
//   costKey[2][3]  – cost = reg[k1] × reg[k2?] × reg[k3?] × (12 if costMonthly)
//
// y1UnitsZero: override Y1 units to 0 (e.g. CAPEX maintenance starts Y2)
model LineTemplate {
  id              String        @id @default(cuid())
  city            String
  domain          String?
  section         BudgetSection
  description     String
  costCategory    InflationType
  unitType        String        @default("")
  position        Int
  isActive        Boolean       @default(true)
  isAutoGenerated Boolean       @default(true)
  notes           String?
  salaryHint      String?
  templateKey     String // stable slug used for upsert seeding

  // unit count
  inputVar           String  @default("fixed_1")
  inputMonthly       Boolean @default(false)
  supervisorRatioKey String?
  inputThreshold     Int? // if set: suppress line (units=0) when inputVar value <= this

  // unit cost
  isSalaryStub   Boolean @default(false)
  userInputCost  String?
  costKey        String?
  costKey2       String?
  costKey3       String?
  costMonthly    Boolean @default(false)
  workerRatioKey String?
  bufferKey      String?
  costPctOf      String?
  costPct        Float?
  y1UnitsZero    Boolean @default(false)

  // Year applicability & expansion / reduction
  applyY1      Boolean @default(true)
  applyY2      Boolean @default(true)
  applyY3      Boolean @default(true)
  y2UnitsScale Float? // null = same as Y1; 1.5 = 50% more; 0.5 = 50% fewer
  y3UnitsScale Float?

  @@unique([city, templateKey])
  @@index([city, domain, position])
}

// ── Layer 3: Programme Journeys ──────────────────────────────────────────────
// Threads connecting multiple goals (across templates / over time) under a
// shared outcome objective. Auto-spawned per (domain, settlement) on goal
// apply. Phases form a DAG (linear by default; admin can rewire).

model ProgrammeJourney {
  id              String    @id @default(cuid())
  // Stable slug for ops + dedupe, e.g. "creche-munireddypalya"
  key             String    @unique
  label           String
  // Auto-linking dimension. Null when admin makes a cross-domain super-journey.
  primaryDomain   String?
  settlementId    String
  status          String    @default("Active") // Active | Paused | Closed
  notes           String?
  // Closure metadata
  closedAt        DateTime?
  closedReason    String?
  closedById      String?
  // Snapshot of final outcome values at closure time (JSON: { outcomeKey: value })
  outcomeSnapshot Json?
  // Optional pointer to a parent super-journey (cross-domain aggregation).
  parentId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  settlement Settlement                @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  parent     ProgrammeJourney?         @relation("ProgrammeJourneyChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children   ProgrammeJourney[]        @relation("ProgrammeJourneyChildren")
  phases     ProgrammeJourneyPhase[]
  outcomes   ProgrammeJourneyOutcome[]
  closedBy   User?                     @relation("JourneyClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([settlementId, primaryDomain])
  @@index([parentId])
}

model ProgrammeJourneyPhase {
  id        String   @id @default(cuid())
  journeyId String
  // Layout hint only — real ordering is the DAG (edges)
  position  Int      @default(0)
  label     String // "Setup" | "Operations" | "Maintenance" | custom
  // Canvas coordinates for the DAG view. Null = auto-layout.
  canvasX   Int?
  canvasY   Int?
  // The fulfilling goal. Null = logical/planned phase not yet started.
  goalId    String?
  status    String   @default("Planned") // Planned | Active | Done | Skipped
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journey  ProgrammeJourney            @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  goal     Goal?                       @relation(fields: [goalId], references: [id], onDelete: SetNull)
  outEdges ProgrammeJourneyPhaseEdge[] @relation("PhaseOutEdges")
  inEdges  ProgrammeJourneyPhaseEdge[] @relation("PhaseInEdges")

  @@index([journeyId])
  @@index([goalId])
}

model ProgrammeJourneyPhaseEdge {
  id          String  @id @default(cuid())
  fromPhaseId String
  toPhaseId   String
  label       String? // "after creche running", "in parallel"

  from ProgrammeJourneyPhase @relation("PhaseOutEdges", fields: [fromPhaseId], references: [id], onDelete: Cascade)
  to   ProgrammeJourneyPhase @relation("PhaseInEdges", fields: [toPhaseId], references: [id], onDelete: Cascade)

  @@unique([fromPhaseId, toPhaseId])
}

model ProgrammeJourneyOutcome {
  id                  String   @id @default(cuid())
  journeyId           String
  key                 String // unique within journey
  label               String
  description         String?
  unit                String?
  // MANUAL_ADMIN | RP_ACTIVITY (mirrors FacilityIndicatorSource)
  captureSource       String   @default("MANUAL_ADMIN")
  // For RP_ACTIVITY: bind to a checklist key (one binding per outcome in v1)
  bindingTemplateSlug String?
  bindingChecklistKey String?
  targetValue         Float?
  targetCadence       String? // "annual" | "quarterly" | "monthly"
  sortOrder           Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  journey ProgrammeJourney               @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  points  ProgrammeJourneyOutcomePoint[]

  @@unique([journeyId, key])
}

model ProgrammeJourneyOutcomePoint {
  id           String   @id @default(cuid())
  outcomeId    String
  value        Float
  capturedAt   DateTime
  source       String // MANUAL_ADMIN | RP_ACTIVITY
  capturedById String?
  sourceRefId  String? // ChecklistItem.id for RP_ACTIVITY
  note         String?
  createdAt    DateTime @default(now())

  outcome    ProgrammeJourneyOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  capturedBy User?                   @relation("JourneyOutcomeCapture", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([outcomeId, capturedAt])
}

// Outcome templates — admin-defined packs that can be applied to any journey
// matching a target domain. Each pack contains one or more outcome definitions
// (label / unit / target / capture mode) that get cloned into a journey on apply.
model ProgrammeJourneyOutcomeTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  // Optional domain filter — admin can apply this pack only to journeys whose
  // primaryDomain matches (or to any journey if null).
  domain    String?
  notes     String?
  // JSON array of outcome definitions to clone into the journey on apply.
  // Shape: [{ key, label, unit, captureSource, bindingTemplateSlug?, bindingChecklistKey?, targetValue?, targetCadence? }]
  outcomes  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── RBAC ──────────────────────────────────────────────────────────────────────
// Centralized role/permission system. User.role (string) is the canonical role
// identifier; it matches Role.name 1:1. Keeping the string column avoids a
// breaking schema change for now — a future migration can swap to an FK.

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "super-admin" | "admin" | "member" | "viewer" | "budget-admin"
  description String?
  isSystem    Boolean  @default(true) // System roles cannot be deleted from admin UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
}

model Permission {
  id        String   @id @default(cuid())
  resource  String // "goal" | "pitstop" | "user" | "thread" | ...
  action    String // "list" | "read" | "create" | "update" | "delete" | special verbs
  createdAt DateTime @default(now())

  roles RolePermission[]

  @@unique([resource, action])
}

// Pivot with the *scope rule* attached. The rule is jsonb so the admin UI can
// edit predicates without a schema migration. See lib/rbac.ts for evaluators.
model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  scopeRule    Json // { kind: "all" | "self" | "own" | "team" | "city" | ... }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
}

// ── Org ──────────────────────────────────────────────────────────────────────
// Tenancy / partner identification. Internal staff share the "Pitstops
// Internal" org seeded via prisma/seed-wiki.ts. Partner NGO orgs are added
// later when partner-user onboarding ships.
model Org {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  kind      String // "internal" | "partner"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  partnerReviewMeetings WikiPartnerReviewMeeting[] @relation("WikiPartnerReviewMeetingOrg")
}

// ── Wiki module ──────────────────────────────────────────────────────────────
// Owner-driven knowledge/practice pages. Per-page owner sits on WikiPage.ownerId;
// global steward/curator powers live in WikiStaff (decoupled from User.role).
// Tag values are free strings under tagType taxonomies. Translations live in
// translatedContent as { lang: { content, translatedAt } }.

model WikiPage {
  id                String    @id @default(cuid())
  slug              String    @unique
  title             String
  type              String // "principle" | "playbook" | "runbook"
  canonicalLang     String    @default("en") // en | ta | kn | ml | hi | bn
  canonicalContent  String    @default("") // markdown serialised from Tiptap
  translatedContent Json      @default("{}") // { ta: { content, translatedAt }, ... }
  ownerId           String?
  ownerTermStart    DateTime?
  ownerTermEnd      DateTime?
  nextReviewDue     DateTime?
  lastReviewedAt    DateTime?
  lastEditedAt      DateTime  @default(now())
  lastEditedById    String?
  status            String    @default("draft") // draft | published | under_review | orphaned | retired
  createdAt         DateTime  @default(now())
  archivedAt        DateTime?

  owner                 User?                      @relation("WikiPageOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  lastEditor            User?                      @relation("WikiPageLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  tags                  WikiPageTag[]
  versions              WikiPageVersion[]
  comments              WikiComment[]
  flags                 WikiFlag[]
  reviews               WikiReviewCycle[]
  notifLogs             WikiNotificationLog[]
  practiceCircles       WikiPracticeCircle[]       @relation("WikiPracticeCirclePages")
  partnerReviewMeetings WikiPartnerReviewMeeting[] @relation("WikiPartnerReviewMeetingPages")
  handovers             WikiOwnerHandover[]
  translationFlags      WikiTranslationFlag[]
  views                 WikiPageView[]

  @@index([status])
  @@index([type])
  @@index([nextReviewDue])
  @@index([ownerId])
  @@index([ownerTermEnd])
}

model WikiPageTag {
  id       String @id @default(cuid())
  pageId   String
  tagType  String // "vertical" | "city" | "partner_org" | "activity_type"
  tagValue String

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, tagType, tagValue])
  @@index([tagType, tagValue])
}

model WikiPageVersion {
  id              String   @id @default(cuid())
  pageId          String
  versionNumber   Int
  contentSnapshot String // full markdown at this version
  language        String // which language was edited
  editedById      String
  editedAt        DateTime @default(now())
  changeNote      String?

  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  editor User     @relation("WikiPageVersionEditor", fields: [editedById], references: [id])

  @@unique([pageId, versionNumber])
  @@index([editedById])
}

model WikiComment {
  id            String    @id @default(cuid())
  pageId        String
  authorId      String
  sectionAnchor String?
  body          String
  language      String
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
  resolvedById  String?

  page       WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author     User     @relation("WikiCommentAuthor", fields: [authorId], references: [id])
  resolvedBy User?    @relation("WikiCommentResolver", fields: [resolvedById], references: [id])

  @@index([pageId])
  @@index([authorId])
}

model WikiFlag {
  id            String    @id @default(cuid())
  pageId        String
  flaggerId     String
  sectionAnchor String?
  reason        String
  status        String    @default("open") // open | acknowledged | resolved
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  page    WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  flagger User     @relation("WikiFlagFlagger", fields: [flaggerId], references: [id])

  @@index([pageId, status])
  @@index([flaggerId])
}

model WikiReviewCycle {
  id                            String    @id @default(cuid())
  pageId                        String
  ownerId                       String
  scheduledFor                  DateTime
  completedAt                   DateTime?
  completionNote                String?
  type                          String // quarterly | post_circle | post_partner_review
  // Legacy free-string trigger from PR1 — superseded by the FK columns below,
  // kept nullable for safety. New code should write to triggerCircleId or
  // triggerPartnerReviewMeetingId instead.
  triggerSourceId               String?
  triggerCircleId               String?
  triggerPartnerReviewMeetingId String?
  createdAt                     DateTime  @default(now())

  page                        WikiPage                  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  owner                       User                      @relation("WikiReviewCycleOwner", fields: [ownerId], references: [id])
  triggerCircle               WikiPracticeCircle?       @relation(fields: [triggerCircleId], references: [id], onDelete: SetNull)
  triggerPartnerReviewMeeting WikiPartnerReviewMeeting? @relation(fields: [triggerPartnerReviewMeetingId], references: [id], onDelete: SetNull)

  @@unique([pageId, triggerCircleId])
  @@unique([pageId, triggerPartnerReviewMeetingId])
  @@index([pageId])
  @@index([ownerId, completedAt])
}

model WikiStaff {
  id        String   @id @default(cuid())
  userId    String
  wikiRole  String // "curator" | "steward"
  scope     Json? // { cities: [...], verticals: [...] } — null = global
  createdAt DateTime @default(now())

  user User @relation("WikiStaffUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, wikiRole])
  @@index([wikiRole])
}

// Notification dispatch audit log. Captures every intended wiki-related
// notification (push / inApp / whatsapp) with status so we can debug why a
// digest didn't fire, and so the WhatsApp adapter — currently a stub — leaves
// a paper trail of "would have sent" intent until the provider is chosen.
model WikiNotificationLog {
  id        String   @id @default(cuid())
  userId    String
  pageId    String?
  kind      String // "wiki_flag_created" | "wiki_comment_created" | "wiki_weekly_digest" | ...
  channel   String // "push" | "inApp" | "whatsapp"
  status    String // "sent" | "skipped" | "failed" | "intended_no_adapter"
  payload   Json
  error     String?
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  page WikiPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([pageId])
  @@index([kind, createdAt])
}

// Practice circle: scheduled internal meeting (vertical + zone scoped) where
// staff discuss a case. Pages linked here get a "review within 7 days" prompt
// to their owners once the circle is marked completed.
model WikiPracticeCircle {
  id            String    @id @default(cuid())
  scheduledFor  DateTime
  completedAt   DateTime?
  vertical      String?
  zoneId        String?
  facilitatorId String
  caseDiscussed String?
  notes         String?
  recordingUrl  String?
  language      String    @default("en")
  createdAt     DateTime  @default(now())

  zone         Zone?             @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  facilitator  User              @relation("WikiPracticeCircleFacilitator", fields: [facilitatorId], references: [id])
  attendees    User[]            @relation("WikiPracticeCircleAttendees")
  linkedPages  WikiPage[]        @relation("WikiPracticeCirclePages")
  reviewCycles WikiReviewCycle[]

  @@index([scheduledFor])
  @@index([facilitatorId])
  @@index([zoneId])
}

// Partner review meeting: scheduled session with a partner NGO where the team
// notes any changes to shared practice. Linked pages get the same post-event
// review prompt as practice circles.
model WikiPartnerReviewMeeting {
  id                   String    @id @default(cuid())
  partnerOrgId         String
  scheduledFor         DateTime
  completedAt          DateTime?
  practiceChangesNoted String?
  notes                String?
  language             String    @default("en")
  createdAt            DateTime  @default(now())

  partnerOrg   Org               @relation("WikiPartnerReviewMeetingOrg", fields: [partnerOrgId], references: [id])
  attendees    User[]            @relation("WikiPartnerReviewMeetingAttendees")
  linkedPages  WikiPage[]        @relation("WikiPartnerReviewMeetingPages")
  reviewCycles WikiReviewCycle[]

  @@index([scheduledFor])
  @@index([partnerOrgId])
}

// Pending or completed owner handover. The owner initiates by inserting a
// pending row addressed to the proposed new owner; the proposed owner then
// accepts (which flips WikiPage.ownerId + resets the term) or declines.
model WikiOwnerHandover {
  id           String    @id @default(cuid())
  pageId       String
  fromUserId   String
  toUserId     String
  handoverNote String?
  status       String    @default("pending") // pending | accepted | declined
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  page     WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  fromUser User     @relation("WikiHandoverFrom", fields: [fromUserId], references: [id])
  toUser   User     @relation("WikiHandoverTo", fields: [toUserId], references: [id])

  @@index([pageId, status])
  @@index([toUserId, status])
}

// Reader-flagged translation quality issue. Goes to a queue for human review.
// Per-language so the same page can have flags against different translations
// simultaneously.
model WikiTranslationFlag {
  id         String    @id @default(cuid())
  pageId     String
  language   String // target language code: ta | kn | ml | hi | bn | en
  flaggerId  String
  reason     String
  status     String    @default("open") // open | resolved
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  page    WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  flagger User     @relation(fields: [flaggerId], references: [id])

  @@index([status])
  @@index([pageId, language])
}

// Per-user, per-page view record — written at most once per (user, page, day)
// from the reader server page. Visible only to stewards and curators per spec
// ("Do not show view counts or popularity to owners or readers — avoids vanity
// dynamics distorting content").
model WikiPageView {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  createdAt DateTime @default(now())

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([userId, createdAt])
}

// ─── Operating Models (parametric unit-economics engine) ─────────────────────
// Templates are *data*, not code. Same pattern as GoalTemplateDef.
// See memory/operating_models.md for the full design.

model ModelTemplate {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "ro_water"
  name        String
  description String   @default("")
  // Time bases this template uses, e.g. [{key:"monthly",length:60},{key:"annual",length:5}].
  // Author-defined; nodes bind to one of these keys (or "scalar").
  horizons    Json     @default("[]")
  // Optional ordering hint for /models lists
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groups    ModelGroup[]
  nodes     ModelNode[]
  outputs   ModelOutput[]
  instances ModelInstance[]
}

// UI grouping for inputs in the play surface (e.g. "Site & Population", "Pricing").
model ModelGroup {
  id         String        @id @default(cuid())
  templateId String
  template   ModelTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key        String // unique within a template
  label      String
  order      Int           @default(0)
  createdAt  DateTime      @default(now())

  nodes ModelNode[]

  @@unique([templateId, key])
  @@index([templateId, order])
}

// A node in the model graph: input cell, formula cell, constant, or table.
// shape encodes whether it's a scalar or vector tied to a template horizon.
// shape examples: {kind:"scalar"} | {kind:"vector", horizon:"monthly"}
model ModelNode {
  id          String        @id @default(cuid())
  templateId  String
  template    ModelTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  groupId     String?
  group       ModelGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  key         String // unique within a template; referenced by formulas
  label       String
  notes       String?
  unit        String? // free text: "INR/litre", "%", "kWh/1000L"
  kind        String // "input" | "formula" | "constant"
  dataType    String // "number" | "percent" | "currency" | "int" | "boolean" | "enum"
  shape       Json          @default("{\"kind\":\"scalar\"}")
  // Default value for input/constant nodes. For vectors, may be a single number
  // (broadcast) or an array. Formulas ignore this.
  defaultJson Json?
  // For formula nodes: the expression source. Null for inputs/constants.
  formula     String?
  // For enum dataType: array of allowed values.
  enumValues  Json?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([templateId, key])
  @@index([templateId, order])
  @@index([groupId])
}

// Author-defined outputs to render: KPI cards, time-series, sensitivity grids,
// scenario comparisons, budget exports. kind drives the renderer; config is
// renderer-specific.
model ModelOutput {
  id         String        @id @default(cuid())
  templateId String
  template   ModelTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key        String
  label      String
  // "kpi" | "series" | "table" | "sensitivity" | "scenarioGrid" | "budgetExport"
  kind       String
  config     Json          @default("{}")
  order      Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([templateId, key])
  @@index([templateId, order])
}

// A saved set of input overrides for a template. Nullable pitstopId supports
// standalone-first then attach-later. parentInstanceId links scenario siblings.
model ModelInstance {
  id               String          @id @default(cuid())
  templateId       String
  template         ModelTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name             String
  pitstopId        String?
  // For scenarios: Conservative/Base/Optimistic share parentInstanceId.
  parentInstanceId String?
  parent           ModelInstance?  @relation("ModelInstanceScenarios", fields: [parentInstanceId], references: [id], onDelete: SetNull)
  scenarios        ModelInstance[] @relation("ModelInstanceScenarios")
  scenarioName     String?
  // Sparse: only the nodes the user has overridden vs. node defaults.
  // Shape: { [nodeKey]: number | number[] | boolean | string }
  inputsJson       Json            @default("{}")
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([templateId, updatedAt])
  @@index([pitstopId])
  @@index([parentInstanceId])
}
