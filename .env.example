# PostgreSQL connection string (from Render dashboard or local Postgres)
DATABASE_URL="postgresql://user:password@host:5432/pitstop"

# NextAuth — set NEXTAUTH_URL to your public domain in production
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# File uploads
# Locally: leave unset (defaults to public/uploads, served by Next.js static files)
# On Render: set to the mounted disk path — files are served via /api/files/
UPLOAD_DIR=/var/data/uploads
